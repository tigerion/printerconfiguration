function setMachineCap(v) { const n = parseInt(v,10); if (!isNaN(n) && n>0) machineCap = n; renderDashboard(); }

// --- SVG stacked/overlaid bar chart: adjusted bar + raw ghost outline ---
function renderChart(series) {
  const W_BAR = 64, GAP = 28, PAD_L = 52, PAD_R = 20, PAD_T = 20, PAD_B = 44;
  const H = 320;
  const plotH = H - PAD_T - PAD_B;
  const W = PAD_L + PAD_R + series.length * W_BAR + (series.length-1) * GAP;
  const maxVal = Math.max(1, ...series.map(s => Math.max(s.raw, s.adjusted)));
  // nice round top
  const niceMax = niceCeil(maxVal);
  const y = v => PAD_T + plotH - (v / niceMax) * plotH;

  // gridlines
  const ticks = 4;
  let grid = '';
  for (let i = 0; i <= ticks; i++) {
    const val = Math.round(niceMax * i / ticks);
    const yy = y(val);
    grid += `<line class="grid-line" x1="${PAD_L}" y1="${yy}" x2="${W-PAD_R}" y2="${yy}"/>`;
    grid += `<text class="grid-label" x="${PAD_L-8}" y="${yy+3}" text-anchor="end">${val}</text>`;
  }

  const bars = series.map((s, i) => {
    const x = PAD_L + i * (W_BAR + GAP);
    const adjY = y(s.adjusted), adjH = (PAD_T + plotH) - adjY;
    const rawY = y(s.raw);
    const rawH = (PAD_T + plotH) - rawY;
    // threat portion (within adjusted, proportional)
    const threatRatio = s.adjusted > 0 ? Math.min(1, s.threat / s.raw) : 0;
    const threatH = adjH * threatRatio;
    const ghost = s.raw > s.adjusted
      ? `<rect class="bar-ghost" x="${x}" y="${rawY}" width="${W_BAR}" height="${rawH}" rx="4"/>`
      : '';
    const removedLabel = s.removed > 0
      ? `<text class="bar-removed-label" x="${x + W_BAR/2}" y="${rawY-4}" text-anchor="middle">+${s.removed}</text>`
      : '';
    return `
      <g class="bar-group" data-i="${i}">
        ${ghost}
        <rect class="bar-seg" x="${x}" y="${adjY}" width="${W_BAR}" height="${adjH}" rx="4" fill="var(--accent)" data-i="${i}"/>
        <rect class="bar-seg" x="${x}" y="${adjY + adjH - threatH}" width="${W_BAR}" height="${threatH}" rx="0" fill="var(--red)" opacity="0.85" data-i="${i}" style="pointer-events:none"/>
        <text class="bar-value-label" x="${x + W_BAR/2}" y="${adjY-6}" text-anchor="middle">${s.adjusted}</text>
        ${removedLabel}
        <text class="bar-month-label" x="${x + W_BAR/2}" y="${H-PAD_B+18}" text-anchor="middle">${fmtMonth(s.month)}</text>
      </g>`;
  }).join('');

  return `
  <div class="chart-panel">
    <div class="chart-head">
      <span class="chart-title">Detections per month &mdash; adjusted load</span>
      <div class="chart-legend">
        <span class="legend-item"><span class="legend-swatch" style="background:var(--accent)"></span>Adjusted load</span>
        <span class="legend-item"><span class="legend-swatch" style="background:var(--red);opacity:0.85"></span>of which threat-level</span>
        <span class="legend-item"><span class="legend-swatch" style="border:1px dashed var(--muted);background:transparent"></span>Raw count (pre-dedup)</span>
      </div>
    </div>
    <div class="chart-scroll">
      <svg class="chart-svg" width="${W}" height="${H}" viewBox="0 0 ${W} ${H}">
        ${grid}
        ${bars}
      </svg>
    </div>
  </div>`;
}

function niceCeil(v) {
  if (v <= 10) return Math.ceil(v);
  const mag = Math.pow(10, Math.floor(Math.log10(v)));
  return Math.ceil(v / (mag/2)) * (mag/2);
}
function fmtMonth(m) {
  const [y, mo] = m.split('-');
  const names = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return names[parseInt(mo,10)-1] + " '" + y.slice(2);
}

function wireChartTooltips(series) {
  const tip = document.getElementById('chartTooltip');
  document.querySelectorAll('.bar-seg').forEach(seg => {
    seg.addEventListener('mousemove', e => {
      const s = series[+seg.dataset.i];
      tip.innerHTML = `
        <div class="tt-title">${fmtMonth(s.month)}</div>
        <div class="tt-row"><span>Raw detections</span><span>${s.raw}</span></div>
        <div class="tt-row"><span>Adjusted load</span><span>${s.adjusted}</span></div>
        <div class="tt-row"><span>Noise removed</span><span>${s.removed}</span></div>
        <div class="tt-row"><span>Threat-level</span><span>${s.threat}</span></div>`;
      tip.classList.add('show');
      tip.style.left = Math.min(e.clientX + 14, window.innerWidth - 260) + 'px';
      tip.style.top  = (e.clientY + 14) + 'px';
    });
    seg.addEventListener('mouseleave', () => tip.classList.remove('show'));
  });
}

// --- breakdown tables: top burst sources + top threats ---
function renderBreakdownTables(rows) {
  // top burst sources: by burst signature, count raw and find max-in-one-hour
  const sig = {};
  rows.forEach(d => {
    const k = burstSignature(d);
    const s = sig[k] || (sig[k] = { label:k, raw:0, hours:{}, threat:0 });
    s.raw++;
    if (d._sev === 'threat') s.threat++;
    const hb = d._hourBucket;
    s.hours[hb] = (s.hours[hb]||0)+1;
  });
  const burstList = Object.values(sig).map(s => {
    s.peak = Math.max(...Object.values(s.hours));
    s.label = s.label.split('|')[0];
    return s;
  }).sort((a,b) => b.raw - a.raw).slice(0, 8);
  const maxBurst = Math.max(1, ...burstList.map(s=>s.raw));

  const burstRows = burstList.map(s => {
    const isBurst = s.peak >= burstCap;
    return `<tr>
      <td class="name barcell" title="${esc(s.label)}">
        ${esc(s.label)}${isBurst?`<span class="tag-burst">PEAK ${s.peak}/h</span>`:''}
        <div class="mini-bar${isBurst?' burst':''}" style="width:${Math.round(s.raw/maxBurst*100)}%"></div>
      </td>
      <td class="num">${s.raw}</td>
    </tr>`;
  }).join('');

  // top threats by name
  const threats = {};
  rows.filter(d=>d._sev==='threat').forEach(d => {
    const k = d.threatName || d.ruleName || '(unknown)';
    threats[k] = (threats[k]||0)+1;
  });
  const threatList = Object.entries(threats).sort((a,b)=>b[1]-a[1]).slice(0,8);
  const maxThreat = Math.max(1, ...threatList.map(t=>t[1]));
  const threatRows = threatList.length ? threatList.map(([name,c]) => `
    <tr>
      <td class="name barcell" title="${esc(name)}">${esc(name)}
        <div class="mini-bar" style="width:${Math.round(c/maxThreat*100)}%;background:var(--red)"></div>
      </td>
      <td class="num">${c}</td>
    </tr>`).join('') : '<tr><td colspan="2" style="color:var(--muted);font-style:italic">No threat-level detections in current filter.</td></tr>';

  return `
  <div class="dash-grid-bottom">
    <div class="table-panel">
      <h3>Top burst sources</h3>
      <div class="panel-hint">Highest-volume rule signatures. A <span style="color:var(--flag)">PEAK</span> tag means one hour hit the burst cap &mdash; a likely update wave.</div>
      <table class="mini-table">
        <thead><tr><th>Rule signature</th><th class="num">Raw</th></tr></thead>
        <tbody>${burstRows}</tbody>
      </table>
    </div>
    <div class="table-panel">
      <h3>Top threats</h3>
      <div class="panel-hint">Highest-count threat-level detections in the current filter &mdash; the ones that warranted real attention.</div>
      <table class="mini-table">
        <thead><tr><th>Threat</th><th class="num">Count</th></tr></thead>
        <tbody>${threatRows}</tbody>
      </table>
    </div>
  </div>`;
}
</script>
