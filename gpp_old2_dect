<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ESET Detection Reviewer</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Syne:wght@400;600;700;800&display=swap');

  :root {
    --bg:        #0d0f14;
    --surface:   #13161e;
    --surface2:  #1a1e28;
    --border:    #252a38;
    --accent:    #4f8ef7;
    --accent2:   #7c3aed;
    --green:     #22c55e;
    --red:       #ef4444;
    --yellow:    #f59e0b;
    --text:      #e2e8f0;
    --muted:     #64748b;
    --code-bg:   #0a0c10;
    --flag:      #f59e0b;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Syne', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ---- DROP ZONE ---- */
  #dropzone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    gap: 24px;
    padding: 40px;
    transition: background 0.2s;
  }
  #dropzone.drag-over { background: rgba(79,142,247,0.06); }

  .drop-logo {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .drop-title {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    text-align: center;
    line-height: 1.1;
    background: linear-gradient(135deg, #e2e8f0 0%, var(--accent) 60%, var(--accent2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .drop-sub {
    color: var(--muted);
    font-size: 15px;
    text-align: center;
    max-width: 420px;
    line-height: 1.6;
  }

  .drop-box {
    border: 2px dashed var(--border);
    border-radius: 16px;
    padding: 48px 64px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .drop-box:hover, .drop-box.active { border-color: var(--accent); background: rgba(79,142,247,0.04); }

  .drop-icon {
    width: 56px; height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
  }

  .drop-label { font-size: 16px; font-weight: 600; }
  .drop-hint  { font-size: 13px; color: var(--muted); }

  #fileInput { display: none; }

  /* ---- APP SHELL ---- */
  #app { display: none; flex-direction: column; height: 100vh; overflow: hidden; }

  /* ---- TOPBAR ---- */
  .topbar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .topbar-brand {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--muted);
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* ---- VIEW TABS ---- */
  .view-tabs { display: flex; gap: 4px; background: var(--surface2); padding: 3px; border-radius: 9px; border: 1px solid var(--border); }
  .view-tab {
    padding: 6px 16px;
    border-radius: 7px;
    border: none;
    background: transparent;
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
  }
  .view-tab:hover  { color: var(--text); }
  .view-tab.active { background: var(--accent); color: #fff; }

  .topbar-stats { display: flex; gap: 10px; flex-wrap: wrap; }

  .stat-chip {
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    border: 1px solid transparent;
  }
  .stat-chip.total    { background: rgba(79,142,247,0.12); border-color: rgba(79,142,247,0.3);  color: var(--accent); }
  .stat-chip.threat   { background: rgba(239,68,68,0.12);  border-color: rgba(239,68,68,0.3);   color: var(--red); }
  .stat-chip.unres    { background: rgba(245,158,11,0.12); border-color: rgba(245,158,11,0.3);  color: var(--yellow); }
  .stat-chip.noted    { background: rgba(34,197,94,0.12);  border-color: rgba(34,197,94,0.3);   color: var(--green); }
  .stat-chip.flagged  { background: rgba(245,158,11,0.12); border-color: rgba(245,158,11,0.3);  color: var(--flag); }

  .topbar-spacer { flex: 1; }
  .topbar-actions { display: flex; gap: 8px; }

  /* ---- FILTER BAR ---- */
  .filterbar {
    display: flex;
    gap: 10px;
    padding: 12px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    align-items: center;
  }

  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 200px;
    max-width: 380px;
  }
  .search-icon {
    position: absolute;
    left: 12px; top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-size: 14px;
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 12px 8px 34px;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s;
  }
  .search-input:focus { border-color: var(--accent); }
  .search-input::placeholder { color: var(--muted); }

  .filter-btn {
    padding: 7px 14px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .filter-btn:hover          { border-color: var(--accent); color: var(--text); }
  .filter-btn.active         { background: var(--accent);  border-color: var(--accent);  color: #fff; }
  .filter-btn.active-red     { background: var(--red);     border-color: var(--red);     color: #fff; }
  .filter-btn.active-yellow  { background: var(--flag);    border-color: var(--flag);    color: #000; }
  .filter-btn.active-green   { background: var(--green);   border-color: var(--green);   color: #000; }

  .filter-label { font-size: 12px; color: var(--muted); font-weight: 600; letter-spacing: 0.05em; }

  /* ---- MAIN LAYOUT ---- */
  .main {
    display: grid;
    grid-template-columns: 300px 1fr;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  /* ---- SIDEBAR ---- */
  .sidebar {
    border-right: 1px solid var(--border);
    overflow-y: auto;
    background: var(--surface);
  }
  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-track { background: transparent; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .sidebar-list { list-style: none; padding: 8px; }

  .sidebar-item {
    padding: 10px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.12s;
    display: flex;
    flex-direction: column;
    gap: 4px;
    border: 1px solid transparent;
    margin-bottom: 2px;
    position: relative;
  }
  .sidebar-item:hover  { background: var(--surface2); }
  .sidebar-item.active { background: var(--surface2); border-color: var(--accent); }
  .sidebar-item.flagged-item::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--flag);
    border-radius: 8px 0 0 8px;
  }

  .item-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .item-meta { display: flex; gap: 6px; align-items: center; }

  .item-sub {
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-style: italic;
  }

  .badge {
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.05em;
  }
  .badge-threat   { background: rgba(239,68,68,0.15);  color: var(--red); }
  .badge-warning  { background: rgba(245,158,11,0.15); color: var(--yellow); }
  .badge-info     { background: rgba(79,142,247,0.15); color: var(--accent); }
  .badge-resolved { background: rgba(34,197,94,0.15);  color: var(--green); }
  .badge-unres    { background: rgba(239,68,68,0.10);  color: var(--red); }
  .badge-note     { background: rgba(34,197,94,0.15);  color: var(--green); }
  .badge-flag     { background: rgba(245,158,11,0.2);  color: var(--flag); }

  /* ---- DETAIL PANEL ---- */
  .detail {
    overflow-y: auto;
    padding: 28px 32px;
    background: var(--bg);
  }
  .detail::-webkit-scrollbar { width: 4px; }
  .detail::-webkit-scrollbar-track { background: transparent; }
  .detail::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .detail-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 12px;
    color: var(--muted);
  }
  .detail-empty-icon { font-size: 48px; opacity: 0.3; }
  .detail-empty-text { font-size: 14px; }

  .detail-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .detail-title {
    font-size: 22px;
    font-weight: 800;
    line-height: 1.2;
    flex: 1;
  }

  .detail-badges { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

  .detail-nav {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .nav-btn {
    padding: 7px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .nav-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; }

  .nav-counter {
    font-size: 13px;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    padding: 0 8px;
    flex: 1;
    text-align: center;
  }

  .flag-btn {
    padding: 7px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .flag-btn:hover   { border-color: var(--flag); color: var(--flag); }
  .flag-btn.flagged { background: rgba(245,158,11,0.15); border-color: var(--flag); color: var(--flag); }

  /* ---- SECTION LABEL ---- */
  .section-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 10px;
  }

  /* ---- NOTE BLOCK ---- */
  .note-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 10px 10px 0;
    padding: 14px 16px;
    font-size: 14px;
    line-height: 1.65;
    margin-bottom: 24px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .note-block.empty { color: var(--muted); font-style: italic; border-left-color: var(--border); }

  /* ---- COMMENTS ---- */
  .comment-thread {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
  }

  .comment-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 6px 10px;
    align-items: start;
  }

  .comment-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: #fff;
    flex-shrink: 0;
  }

  .comment-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }

  .comment-author { font-size: 13px; font-weight: 700; color: var(--text); }
  .comment-time   { font-size: 11px; color: var(--muted); font-family: 'JetBrains Mono', monospace; }
  .comment-edited { font-size: 10px; color: var(--muted); font-style: italic; }

  .comment-body {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text);
    white-space: pre-wrap;
    word-break: break-word;
    grid-column: 2;
  }

  /* ---- FIELDS GRID ---- */
  .fields-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }

  .field-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .field-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .field-value {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    word-break: break-all;
    font-family: 'JetBrains Mono', monospace;
  }
  .field-value.empty  { color: var(--muted); font-style: italic; font-family: 'Syne', sans-serif; font-weight: 400; font-size: 13px; }
  .field-value.red    { color: var(--red); }
  .field-value.yellow { color: var(--yellow); }
  .field-value.green  { color: var(--green); }
  .field-value.blue   { color: var(--accent); }

  /* ---- MONO BLOCK (process / module) ---- */
  .mono-block {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .mono-toolbar {
    display: flex;
    align-items: center;
    padding: 10px 16px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .mono-toolbar-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .mono-body {
    padding: 16px 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    line-height: 1.7;
    color: #94a3b8;
    white-space: pre-wrap;
    word-break: break-all;
  }

  /* ---- BUTTONS ---- */
  .btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }
  .btn:hover        { border-color: var(--accent); }
  .btn.btn-accent   { background: var(--accent); border-color: var(--accent); color: #fff; }
  .btn.btn-accent:hover { background: #3d7ae5; }

  /* ---- MODAL ---- */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    z-index: 100;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    width: 90%;
    max-width: 560px;
    max-height: 80vh;
    overflow-y: auto;
  }

  .modal-title { font-size: 18px; font-weight: 800; margin-bottom: 8px; }
  .modal-sub   { font-size: 13px; color: var(--muted); margin-bottom: 20px; }
  .modal-list  { list-style: none; display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }

  .modal-item {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--flag);
    border-radius: 0 8px 8px 0;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 600;
  }
  .modal-item-id { font-size: 11px; color: var(--muted); font-family: 'JetBrains Mono', monospace; margin-top: 2px; }

  .modal-actions { display: flex; gap: 10px; justify-content: flex-end; }

  /* ---- SCROLLBAR ---- */
  ::-webkit-scrollbar       { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  .no-results { padding: 24px; text-align: center; color: var(--muted); font-size: 13px; }

  /* ============================================================ */
  /* ---- DASHBOARD (new) ---- */
  /* ============================================================ */
  .dashboard {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 24px 32px 48px;
    background: var(--bg);
  }
  .dashboard::-webkit-scrollbar { width: 6px; }
  .dashboard::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  .dash-grid-top {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    margin-bottom: 24px;
  }

  .kpi-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
    overflow: hidden;
  }
  .kpi-card::after {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent);
  }
  .kpi-card.kpi-raw::after      { background: var(--muted); }
  .kpi-card.kpi-adjusted::after { background: var(--accent); }
  .kpi-card.kpi-removed::after  { background: var(--flag); }
  .kpi-card.kpi-threat::after   { background: var(--red); }

  .kpi-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .kpi-value {
    font-size: 30px;
    font-weight: 800;
    font-family: 'JetBrains Mono', monospace;
    line-height: 1;
    color: var(--text);
  }
  .kpi-value.accent { color: var(--accent); }
  .kpi-value.flag   { color: var(--flag); }
  .kpi-value.red    { color: var(--red); }
  .kpi-sub {
    font-size: 12px;
    color: var(--muted);
  }
  .kpi-sub .up   { color: var(--red); font-weight: 700; }
  .kpi-sub .down { color: var(--green); font-weight: 700; }

  /* ---- dedup controls panel ---- */
  .controls-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 20px;
    margin-bottom: 24px;
  }
  .controls-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
    flex-wrap: wrap;
  }
  .controls-title { font-size: 14px; font-weight: 800; }
  .controls-hint  { font-size: 12px; color: var(--muted); line-height: 1.5; margin-bottom: 16px; max-width: 720px; }
  .controls-row {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    align-items: flex-start;
  }
  .control-group { display: flex; flex-direction: column; gap: 8px; min-width: 180px; }
  .control-group > .field-label { margin-bottom: 2px; }

  .seg {
    display: inline-flex;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 3px;
    flex-wrap: wrap;
    gap: 2px;
  }
  .seg button {
    padding: 6px 12px;
    border: none;
    background: transparent;
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 12.5px;
    font-weight: 600;
    cursor: pointer;
    border-radius: 6px;
    transition: all 0.13s;
    white-space: nowrap;
  }
  .seg button:hover  { color: var(--text); }
  .seg button.active { background: var(--accent); color: #fff; }

  .toggle-row { display: flex; align-items: center; gap: 10px; }
  .switch { position: relative; width: 40px; height: 22px; flex-shrink: 0; }
  .switch input { opacity: 0; width: 0; height: 0; }
  .slider {
    position: absolute; inset: 0;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 22px;
    cursor: pointer;
    transition: 0.2s;
  }
  .slider::before {
    content: '';
    position: absolute;
    height: 14px; width: 14px;
    left: 3px; top: 3px;
    background: var(--muted);
    border-radius: 50%;
    transition: 0.2s;
  }
  .switch input:checked + .slider { background: rgba(79,142,247,0.3); border-color: var(--accent); }
  .switch input:checked + .slider::before { transform: translateX(18px); background: var(--accent); }

  .cap-input {
    width: 70px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 6px 10px;
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    outline: none;
  }
  .cap-input:focus { border-color: var(--accent); }
  .cap-input:disabled { opacity: 0.4; }

  .toggle-label { font-size: 12.5px; font-weight: 600; color: var(--text); }
  .toggle-desc  { font-size: 11px; color: var(--muted); }

  /* ---- chart ---- */
  .chart-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px 24px 16px;
    margin-bottom: 24px;
  }
  .chart-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 18px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .chart-title { font-size: 15px; font-weight: 800; }
  .chart-legend { display: flex; gap: 16px; flex-wrap: wrap; }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--muted); }
  .legend-swatch { width: 12px; height: 12px; border-radius: 3px; }

  .chart-scroll { overflow-x: auto; padding-bottom: 8px; }
  .chart-svg { display: block; }
  .bar-month-label { fill: var(--muted); font-size: 11px; font-family: 'JetBrains Mono', monospace; }
  .bar-value-label { fill: var(--text); font-size: 11px; font-weight: 600; font-family: 'JetBrains Mono', monospace; }
  .bar-removed-label { fill: var(--flag); font-size: 10px; font-family: 'JetBrains Mono', monospace; }
  .grid-line { stroke: var(--border); stroke-width: 1; }
  .grid-label { fill: var(--muted); font-size: 10px; font-family: 'JetBrains Mono', monospace; }
  .bar-seg { transition: opacity 0.13s; cursor: pointer; }
  .bar-seg:hover { opacity: 0.82; }
  .bar-ghost { fill: none; stroke: var(--muted); stroke-width: 1; stroke-dasharray: 3 3; opacity: 0.5; }

  /* ---- breakdown tables ---- */
  .dash-grid-bottom {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }
  .table-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 20px;
  }
  .table-panel h3 {
    font-size: 13px;
    font-weight: 800;
    margin-bottom: 4px;
  }
  .table-panel .panel-hint { font-size: 11px; color: var(--muted); margin-bottom: 14px; }
  .mini-table { width: 100%; border-collapse: collapse; }
  .mini-table th {
    text-align: left;
    font-size: 10px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 6px 8px;
    border-bottom: 1px solid var(--border);
  }
  .mini-table th.num, .mini-table td.num { text-align: right; font-family: 'JetBrains Mono', monospace; }
  .mini-table td {
    font-size: 12.5px;
    padding: 8px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }
  .mini-table tr:last-child td { border-bottom: none; }
  .mini-table td.name { font-weight: 600; max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .mini-table .barcell { position: relative; }
  .mini-bar {
    height: 5px;
    background: var(--accent);
    border-radius: 3px;
    margin-top: 3px;
  }
  .mini-bar.burst { background: var(--flag); }
  .tag-burst {
    display: inline-block;
    margin-left: 6px;
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 9px;
    font-weight: 700;
    background: rgba(245,158,11,0.15);
    color: var(--flag);
    font-family: 'JetBrains Mono', monospace;
    vertical-align: middle;
  }

  .tooltip {
    position: fixed;
    pointer-events: none;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 12px;
    z-index: 200;
    max-width: 280px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
    opacity: 0;
    transition: opacity 0.1s;
  }
  .tooltip.show { opacity: 1; }
  .tooltip .tt-title { font-weight: 800; margin-bottom: 6px; font-size: 12.5px; }
  .tooltip .tt-row { display: flex; justify-content: space-between; gap: 16px; font-family: 'JetBrains Mono', monospace; color: var(--muted); }
  .tooltip .tt-row span:last-child { color: var(--text); font-weight: 600; }

  .dash-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    height: 60vh; gap: 12px; color: var(--muted);
  }
  .dash-empty-icon { font-size: 48px; opacity: 0.3; }
</style>
</head>
<body>

<!-- DROP ZONE -->
<div id="dropzone">
  <div class="drop-logo">ESET Inspect</div>
  <h1 class="drop-title">Detection<br>Reviewer</h1>
  <p class="drop-sub">Load your exported JSON file to review detections with analyst notes, comments, and a monthly trend dashboard.</p>
  <div class="drop-box" id="dropBox" onclick="document.getElementById('fileInput').click()">
    <div class="drop-icon">&#128203;</div>
    <div class="drop-label">Drop JSON export here</div>
    <div class="drop-hint">or click to browse &mdash; exported by Export-EsetInspectDetections.ps1</div>
  </div>
  <input type="file" id="fileInput" accept=".json">
  <div id="statusMsg" style="font-size:13px;color:var(--muted);text-align:center;max-width:460px;line-height:1.6;display:none;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 20px;"></div>
</div>

<!-- APP -->
<div id="app">

  <!-- Topbar -->
  <div class="topbar">
    <div class="topbar-brand">ESET &mdash; Detection Reviewer</div>
    <div class="view-tabs">
      <button class="view-tab active" id="tabDash"   onclick="setView('dashboard')">Dashboard</button>
      <button class="view-tab"        id="tabReview" onclick="setView('reviewer')">Reviewer</button>
    </div>
    <div class="topbar-stats" id="topbarStats"></div>
    <div class="topbar-spacer"></div>
    <div class="topbar-actions">
      <button class="btn" onclick="openFlagModal()">&#9873; Export Flagged</button>
      <button class="btn" onclick="resetApp()">&#8617; Load New File</button>
    </div>
  </div>

  <!-- ============================================================ -->
  <!-- DASHBOARD VIEW -->
  <!-- ============================================================ -->
  <div id="dashboardView">

    <!-- Dashboard filter bar -->
    <div class="filterbar">
      <div class="search-wrap">
        <span class="search-icon">&#128269;</span>
        <input class="search-input" type="text" id="dashSearch" placeholder="Filter by threat, rule, computer, module, user..." oninput="renderDashboard()">
      </div>
      <span class="filter-label">Severity:</span>
      <button class="filter-btn active" id="dAll"     onclick="setDashSev('all')">All</button>
      <button class="filter-btn"        id="dThreat"  onclick="setDashSev('threat')">Threat</button>
      <button class="filter-btn"        id="dWarning" onclick="setDashSev('warning')">Warning</button>
      <button class="filter-btn"        id="dInfo"    onclick="setDashSev('info')">Info</button>
      <span class="filter-label">Status:</span>
      <button class="filter-btn"        id="dUnres"   onclick="setDashStatus('unresolved')">Unresolved</button>
      <button class="filter-btn"        id="dRes"     onclick="setDashStatus('resolved')">Resolved</button>
      <span class="filter-label">Computer:</span>
      <select class="cap-input" id="dashComputer" style="width:auto;min-width:140px" onchange="renderDashboard()">
        <option value="">All computers</option>
      </select>
    </div>

    <div class="dashboard" id="dashboardBody"></div>
  </div>

  <!-- ============================================================ -->
  <!-- REVIEWER VIEW -->
  <!-- ============================================================ -->
  <div id="reviewerView" style="display:none; flex-direction:column; flex:1; min-height:0; overflow:hidden;">
    <!-- Filter bar -->
    <div class="filterbar">
      <div class="search-wrap">
        <span class="search-icon">&#128269;</span>
        <input class="search-input" type="text" id="searchInput" placeholder="Search threat, computer, rule, note, analyst..." oninput="applyFilters()">
      </div>
      <span class="filter-label">Severity:</span>
      <button class="filter-btn active" id="fAll"     onclick="setSevFilter('all')">All</button>
      <button class="filter-btn"        id="fThreat"  onclick="setSevFilter('threat')">Threat</button>
      <button class="filter-btn"        id="fWarning" onclick="setSevFilter('warning')">Warning</button>
      <button class="filter-btn"        id="fInfo"    onclick="setSevFilter('info')">Info</button>
      <span class="filter-label">Status:</span>
      <button class="filter-btn"        id="fUnres"   onclick="setStatusFilter('unresolved')">Unresolved</button>
      <button class="filter-btn"        id="fRes"     onclick="setStatusFilter('resolved')">Resolved</button>
      <button class="filter-btn"        id="fNote"    onclick="setStatusFilter('hasnote')">Has Note</button>
      <button class="filter-btn"        id="fNoNote"  onclick="setStatusFilter('nonote')">No Note</button>
      <button class="filter-btn"        id="fFlagged" onclick="setStatusFilter('flagged')">Flagged</button>
    </div>

    <!-- Main -->
    <div class="main">
      <aside class="sidebar">
        <ul class="sidebar-list" id="sidebarList"></ul>
      </aside>
      <section class="detail" id="detailPanel">
        <div class="detail-empty">
          <div class="detail-empty-icon">&#128203;</div>
          <div class="detail-empty-text">Select a detection from the list</div>
        </div>
      </section>
    </div>
  </div>
</div>

<!-- Flag modal -->
<div class="modal-overlay" id="flagModal">
  <div class="modal">
    <div class="modal-title">&#9873; Flagged Detections</div>
    <div class="modal-sub" id="flagModalSub"></div>
    <ul class="modal-list" id="flagList"></ul>
    <div class="modal-actions">
      <button class="btn" onclick="closeFlagModal()">Close</button>
      <button class="btn btn-accent" onclick="downloadFlagged()">&#8681; Download JSON</button>
    </div>
  </div>
</div>

<!-- Chart tooltip -->
<div class="tooltip" id="chartTooltip"></div>

<script>
// ============================================================
// STATE
// ============================================================
let allData      = [];
let filtered     = [];
let flagged      = new Set();
let sevFilter    = 'all';
let statusFilter = 'all';
let curIdx       = 0;
let curView      = 'dashboard';

// dashboard state
let dashSev      = 'all';
let dashStatus   = 'all';
let dedupKey     = 'none';     // none | sha1 | threatComputer | ruleModule
let burstCapOn   = true;
let burstCap     = 10;         // max per signature per hour
let machineCapOn = false;
let machineCap   = 5;          // max same-detection repeats per machine per month

// ============================================================
// FILE LOADING
// ============================================================
const dropzone = document.getElementById('dropzone');
const app      = document.getElementById('app');
const dropBox  = document.getElementById('dropBox');
const fi       = document.getElementById('fileInput');

dropBox.addEventListener('dragover',  e => { e.preventDefault(); dropzone.classList.add('drag-over'); dropBox.classList.add('active'); });
dropBox.addEventListener('dragleave', () => { dropzone.classList.remove('drag-over'); dropBox.classList.remove('active'); });
dropBox.addEventListener('drop', e => {
  e.preventDefault();
  dropzone.classList.remove('drag-over'); dropBox.classList.remove('active');
  if (e.dataTransfer.files[0]) loadFile(e.dataTransfer.files[0]);
});
fi.addEventListener('change', e => { if (e.target.files[0]) loadFile(e.target.files[0]); });

function showStatus(msg, isError) {
  const el = document.getElementById('statusMsg');
  el.style.display = 'block';
  el.style.color   = isError ? 'var(--red)' : 'var(--muted)';
  el.style.borderColor = isError ? 'var(--red)' : 'var(--border)';
  el.innerHTML = msg;
}

function loadFile(file) {
  showStatus('Reading file: <strong>' + file.name + '</strong> (' + (file.size / 1024).toFixed(1) + ' KB)...', false);
  const reader = new FileReader();
  reader.onerror = () => showStatus('FileReader error: could not read the file.', true);
  reader.onload = e => {
    try {
      const raw = e.target.result;
      showStatus('File read OK (' + (raw.length / 1024).toFixed(1) + ' KB). Parsing JSON...', false);
      let parsed;
      try {
        parsed = JSON.parse(raw);
      } catch(parseErr) {
        showStatus(
          '<strong>JSON parse error</strong><br>' + parseErr.message +
          '<br><br>File size: ' + (raw.length / 1024).toFixed(1) + ' KB' +
          '<br>The file may be truncated or contain invalid characters.' +
          '<br><br>First 200 chars of file:<br><code style="font-size:11px;word-break:break-all">' +
          raw.substring(0, 200).replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</code>',
          true);
        return;
      }
      showStatus('JSON parsed OK. Unwrapping structure...', false);
      let records = [];
      if (Array.isArray(parsed)) {
        records = parsed;
        showStatus('Structure: plain array, ' + records.length + ' items.', false);
      } else if (parsed && typeof parsed === 'object') {
        const keys     = Object.keys(parsed);
        const arrayKey = keys.find(k => Array.isArray(parsed[k]));
        if (arrayKey) {
          records = parsed[arrayKey];
          showStatus('Structure: wrapped object, key "' + arrayKey + '", ' + records.length + ' items.', false);
        } else if (parsed.id !== undefined) {
          records = [parsed];
          showStatus('Structure: single detection object.', false);
        } else {
          showStatus(
            '<strong>Unrecognised JSON structure.</strong><br>' +
            'Expected an array of detections but got an object.<br>' +
            'Top-level keys: <code>' + keys.join(', ') + '</code><br><br>' +
            'Make sure you are loading the detections export, not the run log.',
            true);
          return;
        }
      }
      if (records.length === 0) {
        showStatus('<strong>File parsed OK but contains 0 detections.</strong><br>Check that the export ran successfully and contains data.', true);
        return;
      }
      showStatus('Normalising ' + records.length + ' records...', false);
      const errors = [];
      allData = [];
      records.forEach((d, i) => {
        try { allData.push(normalise(d)); }
        catch(normErr) { errors.push('Record ' + i + ': ' + normErr.message); }
      });
      if (allData.length === 0) {
        showStatus(
          '<strong>All ' + records.length + ' records failed to normalise.</strong><br>' +
          'First error: ' + (errors[0] || 'unknown') + '<br><br>' +
          'Sample record keys: <code>' + Object.keys(records[0]||{}).join(', ') + '</code>',
          true);
        return;
      }
      if (errors.length > 0) console.warn('Skipped ' + errors.length + ' records:', errors.slice(0,5));
      showStatus('Loaded ' + allData.length + ' detections. Opening...', false);
      initApp();
    } catch(err) {
      showStatus('<strong>Unexpected error:</strong><br>' + err.message + '<br><pre style="font-size:10px;white-space:pre-wrap">' + (err.stack||'') + '</pre>', true);
    }
  };
  reader.readAsText(file);
}

function normalise(d) {
  const bool = v => v === true || v === 'True' || v === 'true';
  const sev  = (d.severityLabel || scoreToSev(+d.severityScore || 0)).toLowerCase();
  let commentsArray = d.commentsArray;
  if (typeof commentsArray === 'string') {
    try { commentsArray = JSON.parse(commentsArray); } catch(e) { commentsArray = []; }
  }
  if (!Array.isArray(commentsArray)) commentsArray = [];
  const noteStr     = d.note != null ? String(d.note) : '';
  const commentsTxt = d.commentsText != null ? String(d.commentsText) : '';
  const t = d.creationTime ? new Date(d.creationTime) : null;
  return { ...d,
    commentsArray,
    resolved:     bool(d.resolved),
    handled:      bool(d.handled),
    autoResolved: bool(d.autoResolved),
    _sev:         sev,
    _hasNote:     !!(noteStr.trim()),
    _hasComments: !!(commentsTxt.trim()) || commentsArray.length > 0,
    _date:        t && !isNaN(t) ? t : null,
    _month:       t && !isNaN(t) ? t.getFullYear() + '-' + String(t.getMonth()+1).padStart(2,'0') : null,
    _hourBucket:  t && !isNaN(t) ? t.getFullYear() + '-' + t.getMonth() + '-' + t.getDate() + '-' + t.getHours() : null,
  };
}

function scoreToSev(s) {
  if (s >= 70) return 'threat';
  if (s >= 40) return 'warning';
  return 'info';
}

function initApp() {
  flagged.clear(); sevFilter = 'all'; statusFilter = 'all'; curIdx = 0;
  document.getElementById('searchInput').value = '';
  resetFilterBtns();
  applyFilters();
  populateComputerFilter();
  dropzone.style.display = 'none';
  app.style.display = 'flex';
  updateStats();
  setView('dashboard');
}

function resetApp() {
  allData = []; filtered = []; flagged.clear();
  app.style.display = 'none';
  dropzone.style.display = 'flex';
  fi.value = '';
}

// ============================================================
// VIEW SWITCHING
// ============================================================
function setView(v) {
  curView = v;
  const isDash = v === 'dashboard';
  document.getElementById('dashboardView').style.display = isDash ? 'flex' : 'none';
  document.getElementById('dashboardView').style.flexDirection = 'column';
  document.getElementById('dashboardView').style.flex = '1';
  document.getElementById('dashboardView').style.minHeight = '0';
  document.getElementById('reviewerView').style.display  = isDash ? 'none' : 'flex';
  document.getElementById('tabDash').className   = 'view-tab' + (isDash ? ' active' : '');
  document.getElementById('tabReview').className = 'view-tab' + (isDash ? '' : ' active');
  if (isDash) renderDashboard();
}

// ============================================================
// REVIEWER FILTERS
// ============================================================
function setSevFilter(f) { sevFilter = sevFilter === f ? 'all' : f; resetFilterBtns(); applyFilters(); }
function setStatusFilter(f) { statusFilter = statusFilter === f ? 'all' : f; resetFilterBtns(); applyFilters(); }

function resetFilterBtns() {
  const smap = { all: 'active', threat: 'active-red', warning: 'active-yellow', info: 'active' };
  ['all','threat','warning','info'].forEach(k => {
    const el = document.getElementById('f' + k.charAt(0).toUpperCase() + k.slice(1));
    if (el) el.className = 'filter-btn' + (sevFilter === k ? ' ' + (smap[k]||'active') : '');
  });
  const stmap = { unresolved: 'active-red', resolved: 'active-green', hasnote: 'active-green', nonote: 'active', flagged: 'active-yellow' };
  const stids = { unresolved:'fUnres', resolved:'fRes', hasnote:'fNote', nonote:'fNoNote', flagged:'fFlagged' };
  Object.keys(stids).forEach(k => {
    const el = document.getElementById(stids[k]);
    if (el) el.className = 'filter-btn' + (statusFilter === k ? ' ' + (stmap[k]||'active') : '');
  });
}

function applyFilters() {
  const q = document.getElementById('searchInput').value.toLowerCase().trim();
  filtered = allData.filter(d => {
    if (sevFilter !== 'all' && d._sev !== sevFilter) return false;
    if (statusFilter === 'unresolved' && d.resolved)                      return false;
    if (statusFilter === 'resolved'   && !d.resolved)                     return false;
    if (statusFilter === 'hasnote'    && !d._hasNote && !d._hasComments)  return false;
    if (statusFilter === 'nonote'     && (d._hasNote || d._hasComments))  return false;
    if (statusFilter === 'flagged'    && !flagged.has(String(d.id)))      return false;
    if (q) {
      const hay = [d.threatName, d.ruleName, d.typeLabel, d.computerName,
                   d.processUser, d.note, d.commentsText, d.moduleName,
                   d.moduleSha1, d.processCommandLine, String(d.id||'')]
        .filter(Boolean).join(' ').toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
  curIdx = 0;
  renderSidebar();
  if (filtered.length > 0) renderDetail(0);
  else document.getElementById('detailPanel').innerHTML = `
    <div class="detail-empty">
      <div class="detail-empty-icon">&#128269;</div>
      <div class="detail-empty-text">No detections match the current filter</div>
    </div>`;
}

// ============================================================
// SIDEBAR
// ============================================================
function renderSidebar() {
  const list = document.getElementById('sidebarList');
  if (filtered.length === 0) { list.innerHTML = '<li class="no-results">No results</li>'; return; }
  list.innerHTML = filtered.map((d, i) => {
    const sevCls  = d._sev === 'threat' ? 'badge-threat' : d._sev === 'warning' ? 'badge-warning' : 'badge-info';
    const resCls  = d.resolved ? 'badge-resolved' : 'badge-unres';
    const noteBadge = (d._hasNote || d._hasComments) ? '<span class="badge badge-note">NOTE</span>' : '';
    const flagBadge = flagged.has(String(d.id)) ? '<span class="badge badge-flag">&#9873;</span>' : '';
    const sub = d._hasNote
      ? esc(String(d.note).substring(0, 55)) + (String(d.note).length > 55 ? '...' : '')
      : d._hasComments ? '(has analyst comments)' : esc(d.computerName || '');
    return `<li class="sidebar-item${i === curIdx ? ' active' : ''}${flagged.has(String(d.id)) ? ' flagged-item' : ''}" onclick="selectItem(${i})">
      <div class="item-name" title="${esc(d.threatName || d.ruleName || d.typeLabel || '(unknown)')}">${esc(d.threatName || d.ruleName || d.typeLabel || '(unknown)')}</div>
      <div class="item-meta">
        <span class="badge ${sevCls}">${d._sev.toUpperCase()}</span>
        <span class="badge ${resCls}">${d.resolved ? 'RESOLVED' : 'OPEN'}</span>
        ${noteBadge}${flagBadge}
      </div>
      <div class="item-sub">${sub}</div>
    </li>`;
  }).join('');
}

function selectItem(i) {
  curIdx = i;
  renderSidebar();
  renderDetail(i);
  document.querySelectorAll('.sidebar-item')[i]?.scrollIntoView({ block: 'nearest' });
}

function navigate(dir) {
  const n = curIdx + dir;
  if (n >= 0 && n < filtered.length) selectItem(n);
}

// ============================================================
// DETAIL
// ============================================================
function renderDetail(i) {
  const d = filtered[i];
  if (!d) return;
  const isFlagged = flagged.has(String(d.id));
  const sevCls    = d._sev === 'threat' ? 'badge-threat' : d._sev === 'warning' ? 'badge-warning' : 'badge-info';
  const valCls    = d._sev === 'threat' ? 'red' : d._sev === 'warning' ? 'yellow' : 'blue';
  const resCls    = d.resolved ? 'badge-resolved' : 'badge-unres';
  const date      = d.creationTime ? new Date(d.creationTime).toLocaleString() : 'Unknown';
  const noteHtml = `
    <div class="section-label">Analyst Note / Conclusion</div>
    <div class="note-block${d._hasNote ? '' : ' empty'}">${d._hasNote ? esc(String(d.note)) : 'No analyst note recorded for this detection.'}</div>`;
  const comments = getComments(d);
  let commentsHtml = '';
  if (comments.length > 0) {
    const cards = comments.map(c => {
      const initials = (c.authorName || '?').replace(/[\\@]/g, ' ').trim().split(/\s+/).map(x => x[0]||'').join('').toUpperCase().substring(0,2) || '?';
      const ts       = c.creationTime ? new Date(c.creationTime).toLocaleString() : '';
      const edited   = (c.edited || c.lastEditTime) ? '<span class="comment-edited">(edited)</span>' : '';
      const color    = strColor(c.authorName || '?');
      return `<div class="comment-card">
