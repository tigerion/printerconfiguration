// --- dedup signature key for a detection ---
function dedupSignature(d) {
  switch (dedupKey) {
    case 'sha1':           return d.moduleSha1 || ('id:' + d.id);
    case 'threatComputer': return (d.threatName || d.ruleName || '?') + '|' + (d.computerName || '?');
    case 'ruleModule':     return (d.ruleName || '?') + '|' + (d.moduleSha1 || d.moduleName || '?');
    default:               return null;   // 'none' -> every detection is unique
  }
}
// --- burst signature: what counts as "the same alert firing" within an hour ---
function burstSignature(d) {
  // rule + module is the ESET analogue of search_name in Splunk:
  // an update wave trips the same rule on the same module across many machines.
  return (d.ruleName || d.typeLabel || '?') + '|' + (d.moduleSha1 || d.moduleName || d.threatName || '?');
}

// Apply current dashboard filters (sev / status / computer / search) to allData.
function dashFilteredRaw() {
  const q = (document.getElementById('dashSearch').value || '').toLowerCase().trim();
  const comp = document.getElementById('dashComputer').value;
  return allData.filter(d => {
    if (!d._month) return false; // can't place undated detections on a monthly axis
    if (dashSev !== 'all' && d._sev !== dashSev) return false;
    if (dashStatus === 'unresolved' && d.resolved) return false;
    if (dashStatus === 'resolved'   && !d.resolved) return false;
    if (comp && d.computerName !== comp) return false;
    if (q) {
      const hay = [d.threatName, d.ruleName, d.typeLabel, d.computerName, d.processUser,
                   d.moduleName, d.moduleSha1].filter(Boolean).join(' ').toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
}

// Core: turn a filtered list into per-month adjusted counts, applying
// dedup -> machine cap -> hourly burst cap, in that order.
function computeMonthly(rows) {
  // 1. DEDUP: collapse exact duplicates by chosen signature, scoped WITHIN each month
  // (a module that reappears in a later month is still a real detection that month).
  let working = rows;
  if (dedupKey !== 'none') {
    const seen = new Set();
    working = rows.filter(d => {
      const sig = d._month + '||' + dedupSignature(d);
      if (seen.has(sig)) return false;
      seen.add(sig);
      return true;
    });
  }

  // 2. MACHINE CAP: within a month, cap repeats of the same detection signature on one machine
  if (machineCapOn) {
    const perMachine = {}; // month|computer|threat -> count kept
    working = working.filter(d => {
      const key = d._month + '|' + (d.computerName||'?') + '|' + (d.threatName || d.ruleName || '?');
      perMachine[key] = (perMachine[key] || 0) + 1;
      return perMachine[key] <= machineCap;
    });
  }

  // 3. HOURLY BURST CAP: within each (hour, burst-signature) bucket cap the count.
  // This is the Splunk two-stage bin: bucket to hour+signature, cap, then roll to month.
  // Build month -> { raw, adjusted } and capture how much each stage removed.
  const months = {};
  const ensure = m => months[m] || (months[m] = { raw:0, adjusted:0, threat:0, sigBuckets:{} });

  // first pass: raw + group into hour buckets per month
  working.forEach(d => {
    const m = ensure(d._month);
    m.raw++;
    if (d._sev === 'threat') m.threat++;
    if (burstCapOn) {
      const bkey = d._hourBucket + '||' + burstSignature(d);
      m.sigBuckets[bkey] = (m.sigBuckets[bkey] || 0) + 1;
    }
  });

  // second pass: adjusted count
  Object.keys(months).forEach(m => {
    const mo = months[m];
    if (burstCapOn) {
      let adj = 0;
      Object.values(mo.sigBuckets).forEach(c => { adj += Math.min(c, burstCap); });
      mo.adjusted = adj;
    } else {
      mo.adjusted = mo.raw;
    }
    delete mo.sigBuckets;
  });

  return months;
}

function renderDashboard() {
  if (curView !== 'dashboard') return;
  const body = document.getElementById('dashboardBody');
  const rows = dashFilteredRaw();

  if (rows.length === 0) {
    body.innerHTML = `<div class="dash-empty">
      <div class="dash-empty-icon">&#128202;</div>
      <div>No dated detections match the current filters.</div>
    </div>`;
    return;
  }

  const monthsObj = computeMonthly(rows);
  const monthKeys = Object.keys(monthsObj).sort();
  const series = monthKeys.map(m => ({
    month: m,
    raw: monthsObj[m].raw,
    adjusted: monthsObj[m].adjusted,
    threat: monthsObj[m].threat,
    removed: monthsObj[m].raw - monthsObj[m].adjusted,
  }));

  const totalRaw      = series.reduce((s,x)=>s+x.raw,0);
  const totalAdjusted = series.reduce((s,x)=>s+x.adjusted,0);
  const totalRemoved  = totalRaw - totalAdjusted;
  const totalThreat   = series.reduce((s,x)=>s+x.threat,0);

  // trend: compare last month vs first month on adjusted figures
  let trendHtml = '<span class="kpi-sub">single month of data</span>';
  if (series.length >= 2) {
    const first = series[0].adjusted, last = series[series.length-1].adjusted;
    if (first > 0) {
      const pct = Math.round(((last - first) / first) * 100);
      const dir = pct < 0 ? 'down' : 'up';
      const arrow = pct < 0 ? '&darr;' : '&uarr;';
      const word = pct < 0 ? 'lower' : 'higher';
      trendHtml = `<span class="kpi-sub"><span class="${dir}">${arrow} ${Math.abs(pct)}%</span> ${word} than ${series[0].month}</span>`;
    }
  }

  const kpis = `
    <div class="dash-grid-top">
      <div class="kpi-card kpi-adjusted">
        <div class="kpi-label">Adjusted Load (latest)</div>
        <div class="kpi-value accent">${series[series.length-1].adjusted.toLocaleString()}</div>
        ${trendHtml}
      </div>
      <div class="kpi-card kpi-raw">
        <div class="kpi-label">Total Raw Detections</div>
        <div class="kpi-value">${totalRaw.toLocaleString()}</div>
        <div class="kpi-sub">across ${series.length} month${series.length!==1?'s':''}</div>
      </div>
      <div class="kpi-card kpi-adjusted">
        <div class="kpi-label">Total Adjusted Load</div>
        <div class="kpi-value accent">${totalAdjusted.toLocaleString()}</div>
        <div class="kpi-sub">what analysts actually worked</div>
      </div>
      <div class="kpi-card kpi-removed">
        <div class="kpi-label">Noise Removed</div>
        <div class="kpi-value flag">${totalRemoved.toLocaleString()}</div>
        <div class="kpi-sub">${totalRaw>0?Math.round(totalRemoved/totalRaw*100):0}% were bursts / duplicates</div>
      </div>
      <div class="kpi-card kpi-threat">
        <div class="kpi-label">Threat-Level</div>
        <div class="kpi-value red">${totalThreat.toLocaleString()}</div>
        <div class="kpi-sub">high-severity detections</div>
      </div>
    </div>`;

  const controls = renderControls();
  const chart    = renderChart(series);
  const tables   = renderBreakdownTables(rows);

  body.innerHTML = kpis + controls + chart + tables;
  wireChartTooltips(series);
}

