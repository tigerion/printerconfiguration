function getComments(d) {
  if (Array.isArray(d.commentsArray) && d.commentsArray.length > 0) return d.commentsArray;
  if (d.commentsText && String(d.commentsText).trim()) {
    return String(d.commentsText).split(/  \|  /).map(p => {
      const m = p.match(/^\[([^\|]+)\|([^\]]+)\]\s*([\s\S]*)/);
      if (m) return { creationTime: m[1].trim(), authorName: m[2].trim(), comment: m[3].trim() };
      return { authorName: 'Unknown', comment: p.trim() };
    }).filter(c => c.comment);
  }
  return [];
}

function strColor(s) {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = s.charCodeAt(i) + ((h << 5) - h);
  const palette = ['#1a4a7a','#1a6b3c','#7c3aed','#b35c00','#c0392b','#1a5a5a','#4f8ef7'];
  return palette[Math.abs(h) % palette.length];
}

function esc(s) {
  return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function toggleFlag(id) {
  if (flagged.has(id)) flagged.delete(id); else flagged.add(id);
  updateStats(); renderSidebar(); renderDetail(curIdx);
}

function updateStats() {
  const total   = allData.length;
  const threats = allData.filter(d => d._sev === 'threat').length;
  const unres   = allData.filter(d => !d.resolved).length;
  const noted   = allData.filter(d => d._hasNote || d._hasComments).length;
  const nFlag   = flagged.size;
  document.getElementById('topbarStats').innerHTML = `
    <span class="stat-chip total">Total: ${total}</span>
    <span class="stat-chip threat">Threat: ${threats}</span>
    <span class="stat-chip unres">Unresolved: ${unres}</span>
    <span class="stat-chip noted">With Notes: ${noted}</span>
    <span class="stat-chip flagged">Flagged: ${nFlag}</span>`;
}

