<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ESET Exclusion Reviewer</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Syne:wght@400;600;700;800&display=swap');

  :root {
    --bg:        #0d0f14;
    --surface:   #13161e;
    --surface2:  #1a1e28;
    --border:    #252a38;
    --accent:    #4f8ef7;
    --accent2:   #7c3aed;
    --green:     #22c55e;
    --red:       #ef4444;
    --yellow:    #f59e0b;
    --text:      #e2e8f0;
    --muted:     #64748b;
    --code-bg:   #0a0c10;
    --flag:      #f59e0b;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Syne', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ---- DROP ZONE ---- */
  #dropzone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    gap: 24px;
    padding: 40px;
    transition: background 0.2s;
  }
  #dropzone.drag-over { background: rgba(79,142,247,0.06); }

  .drop-logo {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .drop-title {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    text-align: center;
    line-height: 1.1;
    background: linear-gradient(135deg, #e2e8f0 0%, var(--accent) 60%, var(--accent2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .drop-sub {
    color: var(--muted);
    font-size: 15px;
    text-align: center;
    max-width: 420px;
    line-height: 1.6;
  }

  .drop-box {
    border: 2px dashed var(--border);
    border-radius: 16px;
    padding: 48px 64px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .drop-box:hover, .drop-box.active { border-color: var(--accent); background: rgba(79,142,247,0.04); }

  .drop-icon {
    width: 56px; height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
  }

  .drop-label { font-size: 16px; font-weight: 600; }
  .drop-hint  { font-size: 13px; color: var(--muted); }

  #fileInput { display: none; }

  /* ---- APP SHELL ---- */
  #app { display: none; flex-direction: column; min-height: 100vh; }

  /* ---- TOPBAR ---- */
  .topbar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .topbar-brand {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--muted);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .topbar-stats {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .stat-chip {
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    border: 1px solid transparent;
  }
  .stat-chip.total   { background: rgba(79,142,247,0.12); border-color: rgba(79,142,247,0.3);  color: var(--accent); }
  .stat-chip.enabled { background: rgba(34,197,94,0.12);  border-color: rgba(34,197,94,0.3);   color: var(--green); }
  .stat-chip.disabled{ background: rgba(239,68,68,0.12);  border-color: rgba(239,68,68,0.3);   color: var(--red); }
  .stat-chip.flagged { background: rgba(245,158,11,0.12); border-color: rgba(245,158,11,0.3);  color: var(--yellow); }

  .topbar-spacer { flex: 1; }

  .topbar-actions { display: flex; gap: 8px; }

  /* ---- FILTER BAR ---- */
  .filterbar {
    display: flex;
    gap: 10px;
    padding: 12px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    align-items: center;
  }

  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 200px;
    max-width: 380px;
  }
  .search-icon {
    position: absolute;
    left: 12px; top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-size: 14px;
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 12px 8px 34px;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s;
  }
  .search-input:focus { border-color: var(--accent); }
  .search-input::placeholder { color: var(--muted); }

  .filter-btn {
    padding: 7px 14px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .filter-btn:hover          { border-color: var(--accent); color: var(--text); }
  .filter-btn.active         { background: var(--accent); border-color: var(--accent); color: #fff; }
  .filter-btn.active-red     { background: var(--red);    border-color: var(--red);    color: #fff; }
  .filter-btn.active-yellow  { background: var(--flag);   border-color: var(--flag);   color: #000; }

  .filter-label { font-size: 12px; color: var(--muted); font-weight: 600; letter-spacing: 0.05em; }

  /* ---- MAIN LAYOUT ---- */
  .main {
    display: grid;
    grid-template-columns: 280px 1fr;
    flex: 1;
    overflow: hidden;
    height: calc(100vh - 103px);
  }

  /* ---- SIDEBAR ---- */
  .sidebar {
    border-right: 1px solid var(--border);
    overflow-y: auto;
    background: var(--surface);
  }
  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-track { background: transparent; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .sidebar-list { list-style: none; padding: 8px; }

  .sidebar-item {
    padding: 10px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.12s;
    display: flex;
    flex-direction: column;
    gap: 4px;
    border: 1px solid transparent;
    margin-bottom: 2px;
    position: relative;
  }
  .sidebar-item:hover  { background: var(--surface2); }
  .sidebar-item.active { background: var(--surface2); border-color: var(--accent); }
  .sidebar-item.flagged-item::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--flag);
    border-radius: 8px 0 0 8px;
  }

  .item-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .item-meta {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .badge {
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.05em;
  }
  .badge-enabled  { background: rgba(34,197,94,0.15);  color: var(--green); }
  .badge-disabled { background: rgba(239,68,68,0.15);  color: var(--red); }
  .badge-rules    { background: rgba(79,142,247,0.15); color: var(--accent); }
  .badge-flag     { background: rgba(245,158,11,0.2);  color: var(--flag); }
  .badge-noxml    { background: rgba(100,116,139,0.2); color: var(--muted); }

  /* ---- DETAIL PANEL ---- */
  .detail {
    overflow-y: auto;
    padding: 28px 32px;
    background: var(--bg);
  }
  .detail::-webkit-scrollbar { width: 4px; }
  .detail::-webkit-scrollbar-track { background: transparent; }
  .detail::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .detail-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 12px;
    color: var(--muted);
  }
  .detail-empty-icon { font-size: 48px; opacity: 0.3; }
  .detail-empty-text { font-size: 14px; }

  .detail-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .detail-title {
    font-size: 22px;
    font-weight: 800;
    line-height: 1.2;
    flex: 1;
  }

  .detail-badges { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

  .detail-nav {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .nav-btn {
    padding: 7px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .nav-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; }

  .nav-counter {
    font-size: 13px;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    padding: 0 8px;
  }

  .flag-btn {
    padding: 7px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .flag-btn:hover       { border-color: var(--flag); color: var(--flag); }
  .flag-btn.flagged     { background: rgba(245,158,11,0.15); border-color: var(--flag); color: var(--flag); }

  /* ---- FIELDS GRID ---- */
  .fields-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }

  .field-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .field-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .field-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    word-break: break-all;
    font-family: 'JetBrains Mono', monospace;
  }
  .field-value.empty { color: var(--muted); font-style: italic; font-family: 'Syne', sans-serif; font-weight: 400; }

  /* ---- NOTE BLOCK ---- */
  .section-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 10px;
  }

  .note-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 10px 10px 0;
    padding: 14px 16px;
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 24px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .note-block.empty { color: var(--muted); font-style: italic; border-left-color: var(--border); }

  /* ---- RULES BLOCK ---- */
  .rules-block {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  .rule-chip {
    padding: 5px 12px;
    border-radius: 6px;
    background: rgba(79,142,247,0.1);
    border: 1px solid rgba(79,142,247,0.25);
    color: var(--accent);
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
  }

  /* ---- XML BLOCK ---- */
  .xml-wrap {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .xml-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .xml-toolbar-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .copy-btn {
    padding: 4px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .copy-btn:hover { border-color: var(--accent); color: var(--accent); }
  .copy-btn.copied { border-color: var(--green); color: var(--green); }

  .xml-code {
    padding: 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    line-height: 1.7;
    overflow-x: auto;
    white-space: pre;
    color: #94a3b8;
    max-height: 480px;
    overflow-y: auto;
  }
  .xml-code::-webkit-scrollbar { width: 4px; height: 4px; }
  .xml-code::-webkit-scrollbar-track { background: transparent; }
  .xml-code::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* XML syntax highlighting */
  .xml-tag       { color: #7dd3fc; }
  .xml-attr      { color: #86efac; }
  .xml-val       { color: #fca5a5; }
  .xml-comment   { color: #475569; font-style: italic; }
  .xml-text      { color: #e2e8f0; }

  .xml-empty {
    padding: 20px;
    color: var(--muted);
    font-style: italic;
    font-family: 'Syne', sans-serif;
    font-size: 14px;
  }

  /* ---- BUTTONS ---- */
  .btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }
  .btn:hover          { border-color: var(--accent); }
  .btn.btn-accent     { background: var(--accent); border-color: var(--accent); color: #fff; }
  .btn.btn-accent:hover { background: #3d7ae5; }
  .btn.btn-danger     { background: rgba(239,68,68,0.1); border-color: var(--red); color: var(--red); }

  /* ---- EXPORT MODAL ---- */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    z-index: 100;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    width: 90%;
    max-width: 560px;
    max-height: 80vh;
    overflow-y: auto;
  }

  .modal-title {
    font-size: 18px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .modal-sub { font-size: 13px; color: var(--muted); margin-bottom: 20px; }

  .modal-list { list-style: none; display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }

  .modal-item {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--flag);
    border-radius: 0 8px 8px 0;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 600;
  }

  .modal-item-id { font-size: 11px; color: var(--muted); font-family: 'JetBrains Mono', monospace; margin-top: 2px; }

  .modal-actions { display: flex; gap: 10px; justify-content: flex-end; }

  /* ---- SCROLLBAR GLOBAL ---- */
  ::-webkit-scrollbar       { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  .no-results {
    padding: 24px;
    text-align: center;
    color: var(--muted);
    font-size: 13px;
  }
</style>
</head>
<body>

<!-- DROP ZONE -->
<div id="dropzone">
  <div class="drop-logo">ESET Inspect</div>
  <h1 class="drop-title">Exclusion<br>Reviewer</h1>
  <p class="drop-sub">Load your exported JSON file to review exclusions one by one with full XML criteria visibility.</p>
  <div class="drop-box" id="dropBox" onclick="document.getElementById('fileInput').click()">
    <div class="drop-icon">&#128196;</div>
    <div class="drop-label">Drop JSON export here</div>
    <div class="drop-hint">or click to browse &mdash; exported by Export-EsetInspectExclusions.ps1</div>
  </div>
  <input type="file" id="fileInput" accept=".json">
</div>

<!-- APP -->
<div id="app">
  <!-- Top bar -->
  <div class="topbar">
    <div class="topbar-brand">ESET &mdash; Exclusion Reviewer</div>
    <div class="topbar-stats" id="topbarStats"></div>
    <div class="topbar-spacer"></div>
    <div class="topbar-actions">
      <button class="btn" onclick="openFlagModal()" id="exportFlagBtn">&#9873; Export Flagged</button>
      <button class="btn" onclick="resetApp()">&#8617; Load New File</button>
    </div>
  </div>

  <!-- Filter bar -->
  <div class="filterbar">
    <div class="search-wrap">
      <span class="search-icon">&#128269;</span>
      <input class="search-input" type="text" id="searchInput" placeholder="Search by name, note, rule ID..." oninput="applyFilters()">
    </div>
    <span class="filter-label">Show:</span>
    <button class="filter-btn active" id="filterAll"      onclick="setFilter('all')">All</button>
    <button class="filter-btn"        id="filterEnabled"  onclick="setFilter('enabled')">Enabled</button>
    <button class="filter-btn"        id="filterDisabled" onclick="setFilter('disabled')">Disabled</button>
    <button class="filter-btn"        id="filterFlagged"  onclick="setFilter('flagged')">Flagged</button>
    <button class="filter-btn"        id="filterNoRules"  onclick="setFilter('norules')">No Rules</button>
  </div>

  <!-- Main -->
  <div class="main">
    <aside class="sidebar">
      <ul class="sidebar-list" id="sidebarList"></ul>
    </aside>
    <section class="detail" id="detailPanel">
      <div class="detail-empty">
        <div class="detail-empty-icon">&#128196;</div>
        <div class="detail-empty-text">Select an exclusion from the list</div>
      </div>
    </section>
  </div>
</div>

<!-- Flag export modal -->
<div class="modal-overlay" id="flagModal">
  <div class="modal">
    <div class="modal-title">&#9873; Flagged Exclusions</div>
    <div class="modal-sub" id="flagModalSub"></div>
    <ul class="modal-list" id="flagList"></ul>
    <div class="modal-actions">
      <button class="btn" onclick="closeFlagModal()">Close</button>
      <button class="btn btn-accent" onclick="downloadFlagged()">&#8681; Download JSON</button>
    </div>
  </div>
</div>

<script>
let allData       = [];
let filteredData  = [];
let flagged       = new Set();
let currentFilter = 'all';
let currentIndex  = 0;

// ---- FILE LOADING ----------------------------------------------------------

const dropzone  = document.getElementById('dropzone');
const app       = document.getElementById('app');
const fileInput = document.getElementById('fileInput');
const dropBox   = document.getElementById('dropBox');

dropBox.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('drag-over'); dropBox.classList.add('active'); });
dropBox.addEventListener('dragleave', () => { dropzone.classList.remove('drag-over'); dropBox.classList.remove('active'); });
dropBox.addEventListener('drop', e => {
  e.preventDefault();
  dropzone.classList.remove('drag-over');
  dropBox.classList.remove('active');
  const file = e.dataTransfer.files[0];
  if (file) loadFile(file);
});

fileInput.addEventListener('change', e => { if (e.target.files[0]) loadFile(e.target.files[0]); });

function loadFile(file) {
  const reader = new FileReader();
  reader.onload = e => {
    try {
      let parsed = JSON.parse(e.target.result);
      // Handle both raw array and wrapped object
      if (Array.isArray(parsed)) {
        allData = parsed;
      } else if (parsed.value && Array.isArray(parsed.value)) {
        allData = parsed.value;
      } else {
        allData = [parsed];
      }
      // Normalise boolean fields that may come as strings
      allData = allData.map(d => ({
        ...d,
        enabled:    d.enabled === true || d.enabled === 'True' || d.enabled === 'true',
        isDisabled: d.isDisabled === true || d.isDisabled === 'True' || d.isDisabled === 'true'
            || !(d.enabled === true || d.enabled === 'True' || d.enabled === 'true'),
        hasXml:     !!(d.xmlBody && d.xmlBody.trim() !== ''),
        linkedRules: !!(d.ruleIds && d.ruleIds.toString().trim() !== ''),
        ruleCount:  d.ruleCount || (d.ruleIds ? d.ruleIds.toString().split(',').filter(x => x.trim()).length : 0),
      }));
      initApp();
    } catch(err) {
      alert('Failed to parse JSON file:\n' + err.message);
    }
  };
  reader.readAsText(file);
}

function initApp() {
  flagged.clear();
  currentFilter = 'all';
  currentIndex  = 0;
  document.getElementById('searchInput').value = '';
  setFilter('all');
  dropzone.style.display = 'none';
  app.style.display = 'flex';
  updateStats();
}

function resetApp() {
  allData = []; filteredData = []; flagged.clear();
  app.style.display = 'none';
  dropzone.style.display = 'flex';
  fileInput.value = '';
}

// ---- FILTERING -------------------------------------------------------------

function setFilter(f) {
  currentFilter = f;
  ['all','enabled','disabled','flagged','norules'].forEach(k => {
    const btn = document.getElementById('filter' + k.charAt(0).toUpperCase() + k.slice(1));
    if (btn) {
      btn.classList.remove('active','active-red','active-yellow');
      if (k === f) {
        if (k === 'disabled') btn.classList.add('active-red');
        else if (k === 'flagged') btn.classList.add('active-yellow');
        else btn.classList.add('active');
      }
    }
  });
  applyFilters();
}

function applyFilters() {
  const q = document.getElementById('searchInput').value.toLowerCase().trim();
  filteredData = allData.filter(d => {
    if (currentFilter === 'enabled'  && d.isDisabled)      return false;
    if (currentFilter === 'disabled' && !d.isDisabled)     return false;
    if (currentFilter === 'flagged'  && !flagged.has(d.id)) return false;
    if (currentFilter === 'norules'  && d.linkedRules)      return false;
    if (q) {
      const haystack = [d.name, d.note, d.ruleIds, d.ruleUuids, d.uuid, d.xmlBody]
        .filter(Boolean).join(' ').toLowerCase();
      if (!haystack.includes(q)) return false;
    }
    return true;
  });

  currentIndex = 0;
  renderSidebar();
  if (filteredData.length > 0) renderDetail(0);
  else document.getElementById('detailPanel').innerHTML = `
    <div class="detail-empty">
      <div class="detail-empty-icon">&#128269;</div>
      <div class="detail-empty-text">No exclusions match the current filter</div>
    </div>`;
}

// ---- SIDEBAR ---------------------------------------------------------------

function renderSidebar() {
  const list = document.getElementById('sidebarList');
  if (filteredData.length === 0) {
    list.innerHTML = '<li class="no-results">No results</li>';
    return;
  }
  list.innerHTML = filteredData.map((d, i) => {
    const isFlagged  = flagged.has(d.id);
    const statusBadge = d.isDisabled
      ? '<span class="badge badge-disabled">DISABLED</span>'
      : '<span class="badge badge-enabled">ENABLED</span>';
    const ruleBadge = d.linkedRules
      ? `<span class="badge badge-rules">${d.ruleCount} rule${d.ruleCount !== 1 ? 's' : ''}</span>`
      : '';
    const flagBadge  = isFlagged ? '<span class="badge badge-flag">&#9873;</span>' : '';
    const xmlBadge   = !d.hasXml ? '<span class="badge badge-noxml">no XML</span>' : '';
    return `<li class="sidebar-item${i === currentIndex ? ' active' : ''}${isFlagged ? ' flagged-item' : ''}"
               onclick="selectItem(${i})">
      <div class="item-name" title="${esc(d.name || '(unnamed)')}">${esc(d.name || '(unnamed)')}</div>
      <div class="item-meta">${statusBadge}${ruleBadge}${flagBadge}${xmlBadge}</div>
    </li>`;
  }).join('');
}

function selectItem(i) {
  currentIndex = i;
  renderSidebar();
  renderDetail(i);
  // Scroll selected item into view
  const items = document.querySelectorAll('.sidebar-item');
  if (items[i]) items[i].scrollIntoView({ block: 'nearest' });
}

// ---- DETAIL PANEL ----------------------------------------------------------

function renderDetail(i) {
  const d = filteredData[i];
  if (!d) return;

  const isFlagged = flagged.has(d.id);
  const statusBadge = d.isDisabled
    ? '<span class="badge badge-disabled" style="font-size:13px;padding:4px 10px">DISABLED</span>'
    : '<span class="badge badge-enabled"  style="font-size:13px;padding:4px 10px">ENABLED</span>';

  // Build rules section
  const ruleIdsArr   = d.ruleIds   ? d.ruleIds.toString().split(',').map(x => x.trim()).filter(Boolean) : [];
  const ruleUuidsArr = d.ruleUuids ? d.ruleUuids.toString().split(',').map(x => x.trim()).filter(Boolean) : [];
  const rulesHtml = ruleIdsArr.length > 0
    ? ruleIdsArr.map((id, idx) => {
        const uuid = ruleUuidsArr[idx] ? ` &mdash; <span style="opacity:0.6">${esc(ruleUuidsArr[idx])}</span>` : '';
        return `<div class="rule-chip">Rule ID: ${esc(id)}${uuid}</div>`;
      }).join('')
    : '<span style="color:var(--muted);font-size:13px;font-style:italic">Not linked to any rule (global exclusion)</span>';

  // XML
  const xmlHtml = d.hasXml
    ? `<div class="xml-wrap">
        <div class="xml-toolbar">
          <span class="xml-toolbar-label">XML Criteria Body</span>
          <button class="copy-btn" id="copyBtn" onclick="copyXml()">Copy XML</button>
        </div>
        <div class="xml-code" id="xmlCode">${highlightXml(d.xmlBody)}</div>
       </div>`
    : `<div class="xml-wrap">
        <div class="xml-toolbar"><span class="xml-toolbar-label">XML Criteria Body</span></div>
        <div class="xml-empty">No XML body &mdash; this exclusion has no criteria or was exported without -FetchDetails</div>
       </div>`;

  document.getElementById('detailPanel').innerHTML = `
    <div class="detail-nav">
      <button class="nav-btn" onclick="navigate(-1)" ${i === 0 ? 'disabled' : ''}>&larr; Prev</button>
      <span class="nav-counter">${i + 1} / ${filteredData.length}</span>
      <button class="nav-btn" onclick="navigate(1)" ${i === filteredData.length - 1 ? 'disabled' : ''}>Next &rarr;</button>
      <div style="flex:1"></div>
      <button class="flag-btn${isFlagged ? ' flagged' : ''}" onclick="toggleFlag('${d.id}')">
        &#9873; ${isFlagged ? 'Unflag' : 'Flag for review'}
      </button>
    </div>

    <div class="detail-header">
      <div class="detail-title">${esc(d.name || '(unnamed)')}</div>
      <div class="detail-badges">${statusBadge}</div>
    </div>

    <div class="fields-grid">
      <div class="field-card">
        <div class="field-label">ID</div>
        <div class="field-value">${esc(d.id ?? '')}</div>
      </div>
      <div class="field-card">
        <div class="field-label">UUID</div>
        <div class="field-value" style="font-size:11px">${esc(d.uuid ?? '')}</div>
      </div>
      <div class="field-card">
        <div class="field-label">Has XML Criteria</div>
        <div class="field-value" style="color:${d.hasXml ? 'var(--green)' : 'var(--muted)'}">${d.hasXml ? 'Yes' : 'No'}</div>
      </div>
      <div class="field-card">
        <div class="field-label">Linked Rules</div>
        <div class="field-value" style="color:${d.linkedRules ? 'var(--accent)' : 'var(--muted)'}">${d.ruleCount || 0} rule${d.ruleCount !== 1 ? 's' : ''}</div>
      </div>
    </div>

    <div class="section-label">Note</div>
    <div class="note-block${!d.note || d.note.trim() === '' ? ' empty' : ''}">${d.note && d.note.trim() !== '' ? esc(d.note) : 'No note set'}</div>

    <div class="section-label">Linked Rules</div>
    <div class="rules-block">${rulesHtml}</div>

    ${xmlHtml}
  `;
}

function navigate(dir) {
  const next = currentIndex + dir;
  if (next >= 0 && next < filteredData.length) selectItem(next);
}

// ---- FLAG / EXPORT ---------------------------------------------------------

function toggleFlag(id) {
  if (flagged.has(id)) flagged.delete(id);
  else flagged.add(id);
  updateStats();
  renderSidebar();
  renderDetail(currentIndex);
}

function updateStats() {
  const total    = allData.length;
  const enabled  = allData.filter(d => !d.isDisabled).length;
  const disabled = allData.filter(d =>  d.isDisabled).length;
  const nFlagged = flagged.size;
  document.getElementById('topbarStats').innerHTML = `
    <span class="stat-chip total">Total: ${total}</span>
    <span class="stat-chip enabled">Enabled: ${enabled}</span>
    <span class="stat-chip disabled">Disabled: ${disabled}</span>
    <span class="stat-chip flagged">Flagged: ${nFlagged}</span>
  `;
}

function openFlagModal() {
  const flaggedItems = allData.filter(d => flagged.has(d.id));
  const sub = document.getElementById('flagModalSub');
  const list = document.getElementById('flagList');

  if (flaggedItems.length === 0) {
    sub.textContent  = 'No exclusions have been flagged yet. Use the "Flag for review" button on each exclusion.';
    list.innerHTML   = '';
  } else {
    sub.textContent = `${flaggedItems.length} exclusion${flaggedItems.length !== 1 ? 's' : ''} flagged for review.`;
    list.innerHTML  = flaggedItems.map(d => `
      <li class="modal-item">
        <div>${esc(d.name || '(unnamed)')}</div>
        <div class="modal-item-id">ID: ${esc(d.id ?? '')} &nbsp;|&nbsp; ${d.isDisabled ? 'DISABLED' : 'ENABLED'}</div>
      </li>`).join('');
  }
  document.getElementById('flagModal').classList.add('open');
}

function closeFlagModal() {
  document.getElementById('flagModal').classList.remove('open');
}

function downloadFlagged() {
  const flaggedItems = allData.filter(d => flagged.has(d.id));
  if (flaggedItems.length === 0) { alert('No flagged exclusions to export.'); return; }
  const blob = new Blob([JSON.stringify(flaggedItems, null, 2)], { type: 'application/json' });
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  a.download = `ESET_Flagged_Exclusions_${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  closeFlagModal();
}

// ---- XML COPY --------------------------------------------------------------

function copyXml() {
  const d = filteredData[currentIndex];
  if (!d || !d.xmlBody) return;
  navigator.clipboard.writeText(d.xmlBody).then(() => {
    const btn = document.getElementById('copyBtn');
    if (btn) { btn.textContent = 'Copied!'; btn.classList.add('copied'); setTimeout(() => { btn.textContent = 'Copy XML'; btn.classList.remove('copied'); }, 2000); }
  });
}

// ---- XML SYNTAX HIGHLIGHT --------------------------------------------------

function highlightXml(xml) {
  if (!xml) return '';
  // Escape HTML first
  let s = xml.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  // Comments
  s = s.replace(/(&lt;!--[\s\S]*?--&gt;)/g, '<span class="xml-comment">$1</span>');
  // Tags with attributes
  s = s.replace(/(&lt;\/?)([\w:\-\.]+)((?:\s+[\w:\-\.]+\s*=\s*&quot;[^&]*&quot;)*)\s*(\/?&gt;)/g,
    (_, open, tag, attrs, close) => {
      const attrsHtml = attrs.replace(/([\w:\-\.]+)\s*=\s*(&quot;[^&]*&quot;)/g,
        '<span class="xml-attr">$1</span>=<span class="xml-val">$2</span>');
      return `${open}<span class="xml-tag">${tag}</span>${attrsHtml}${close}`;
    });
  // Self-closing tags without attributes
  s = s.replace(/(&lt;\/?)([\w:\-\.]+)(\s*\/?&gt;)/g,
    (m, open, tag, close) => `${open}<span class="xml-tag">${tag}</span>${close}`);
  return s;
}

// ---- UTILS -----------------------------------------------------------------

function esc(s) {
  return String(s ?? '')
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
}

// Keyboard navigation
document.addEventListener('keydown', e => {
  if (app.style.display === 'none') return;
  if (document.getElementById('flagModal').classList.contains('open')) return;
  if (e.target.tagName === 'INPUT') return;
  if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); navigate(1); }
  if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); navigate(-1); }
  if (e.key === 'f' || e.key === 'F') {
    const d = filteredData[currentIndex];
    if (d) toggleFlag(d.id);
  }
});
</script>
