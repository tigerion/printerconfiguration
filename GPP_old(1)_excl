<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ESET Exclusion Reviewer</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Syne:wght@400;600;700;800&display=swap');

  :root {
    --bg:        #0d0f14;
    --surface:   #13161e;
    --surface2:  #1a1e28;
    --border:    #252a38;
    --accent:    #4f8ef7;
    --accent2:   #7c3aed;
    --green:     #22c55e;
    --red:       #ef4444;
    --yellow:    #f59e0b;
    --text:      #e2e8f0;
    --muted:     #64748b;
    --code-bg:   #0a0c10;
    --flag:      #f59e0b;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Syne', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ---- DROP ZONE ---- */
  #dropzone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    gap: 24px;
    padding: 40px;
    transition: background 0.2s;
  }
  #dropzone.drag-over { background: rgba(79,142,247,0.06); }

  .drop-logo {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .drop-title {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    text-align: center;
    line-height: 1.1;
    background: linear-gradient(135deg, #e2e8f0 0%, var(--accent) 60%, var(--accent2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .drop-sub {
    color: var(--muted);
    font-size: 15px;
    text-align: center;
    max-width: 420px;
    line-height: 1.6;
  }

  .drop-box {
    border: 2px dashed var(--border);
    border-radius: 16px;
    padding: 48px 64px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .drop-box:hover, .drop-box.active { border-color: var(--accent); background: rgba(79,142,247,0.04); }

  .drop-icon {
    width: 56px; height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
  }

  .drop-label { font-size: 16px; font-weight: 600; }
  .drop-hint  { font-size: 13px; color: var(--muted); }

  #fileInput { display: none; }

  /* ---- APP SHELL ---- */
  #app { display: none; flex-direction: column; height: 100vh; overflow: hidden; }

  /* ---- TOPBAR ---- */
  .topbar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .topbar-brand {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--muted);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .topbar-stats {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .stat-chip {
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    border: 1px solid transparent;
  }
  .stat-chip.total   { background: rgba(79,142,247,0.12); border-color: rgba(79,142,247,0.3);  color: var(--accent); }
  .stat-chip.enabled { background: rgba(34,197,94,0.12);  border-color: rgba(34,197,94,0.3);   color: var(--green); }
  .stat-chip.disabled{ background: rgba(239,68,68,0.12);  border-color: rgba(239,68,68,0.3);   color: var(--red); }
  .stat-chip.flagged { background: rgba(245,158,11,0.12); border-color: rgba(245,158,11,0.3);  color: var(--yellow); }

  .topbar-spacer { flex: 1; }

  .topbar-actions { display: flex; gap: 8px; }

  /* ---- FILTER BAR ---- */
  .filterbar {
    display: flex;
    gap: 10px;
    padding: 12px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    align-items: center;
  }

  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 200px;
    max-width: 380px;
  }
  .search-icon {
    position: absolute;
    left: 12px; top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-size: 14px;
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 12px 8px 34px;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s;
  }
  .search-input:focus { border-color: var(--accent); }
  .search-input::placeholder { color: var(--muted); }

  .filter-btn {
    padding: 7px 14px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .filter-btn:hover          { border-color: var(--accent); color: var(--text); }
  .filter-btn.active         { background: var(--accent); border-color: var(--accent); color: #fff; }
  .filter-btn.active-red     { background: var(--red);    border-color: var(--red);    color: #fff; }
  .filter-btn.active-yellow  { background: var(--flag);   border-color: var(--flag);   color: #000; }
  .filter-btn.active-green   { background: var(--green);  border-color: var(--green);  color: #000; }
  .filter-btn.active-purple  { background: var(--accent2);border-color: var(--accent2);color: #fff; }

  .filter-label { font-size: 12px; color: var(--muted); font-weight: 600; letter-spacing: 0.05em; }

  /* ---- STATS PANEL ---- */
  .stats-panel { background: var(--surface); border-bottom: 1px solid var(--border); padding: 14px 24px; display: none; }
  .stats-panel.open { display: block; }
  .stats-header { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; }
  .stats-title { font-size: 12px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; flex: 1; }
  .stats-toggle { padding: 3px 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--surface2); color: var(--muted); font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 600; cursor: pointer; transition: all 0.15s; }
  .stats-toggle:hover { border-color: var(--accent); color: var(--text); }
  .stats-toggle.on { background: var(--accent); border-color: var(--accent); color: #fff; }
  .stats-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .stats-row { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; padding: 8px 14px; display: flex; align-items: center; gap: 10px; cursor: pointer; transition: all 0.15s; user-select: none; min-width: 200px; }
  .stats-row:hover { border-color: var(--accent); }
  .stats-row.excluded { opacity: 0.35; }
  .stats-row.excluded .stats-name { text-decoration: line-through; }
  .stats-name  { font-size: 13px; font-weight: 600; color: var(--text); flex: 1; }
  .stats-count { font-size: 12px; font-family: 'JetBrains Mono', monospace; color: var(--accent); white-space: nowrap; }
  .stats-bar-wrap { flex: 1; min-width: 60px; height: 5px; background: var(--border); border-radius: 3px; overflow: hidden; }
  .stats-bar { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.3s; }

  /* ---- MAIN LAYOUT ---- */
  .main {
    display: grid;
    grid-template-columns: 280px 1fr;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  /* ---- SIDEBAR ---- */
  .sidebar {
    border-right: 1px solid var(--border);
    overflow-y: auto;
    background: var(--surface);
  }
  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-track { background: transparent; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .sidebar-list { list-style: none; padding: 8px; }

  .sidebar-item {
    padding: 10px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.12s;
    display: flex;
    flex-direction: column;
    gap: 4px;
    border: 1px solid transparent;
    margin-bottom: 2px;
    position: relative;
  }
  .sidebar-item:hover  { background: var(--surface2); }
  .sidebar-item.active { background: var(--surface2); border-color: var(--accent); }
  .sidebar-item.flagged-item::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--flag);
    border-radius: 8px 0 0 8px;
  }

  .item-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .item-meta {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .badge {
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.05em;
  }
  .badge-enabled  { background: rgba(34,197,94,0.15);  color: var(--green); }
  .badge-disabled { background: rgba(239,68,68,0.15);  color: var(--red); }
  .badge-rules    { background: rgba(79,142,247,0.15); color: var(--accent); }
  .badge-flag     { background: rgba(245,158,11,0.2);  color: var(--flag); }
  .badge-noxml    { background: rgba(100,116,139,0.2); color: var(--muted); }

  /* ---- DETAIL PANEL ---- */
  .detail {
    overflow-y: auto;
    padding: 28px 32px;
    background: var(--bg);
  }
  .detail::-webkit-scrollbar { width: 4px; }
  .detail::-webkit-scrollbar-track { background: transparent; }
  .detail::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .detail-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 12px;
    color: var(--muted);
  }
  .detail-empty-icon { font-size: 48px; opacity: 0.3; }
  .detail-empty-text { font-size: 14px; }

  .detail-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .detail-title {
    font-size: 22px;
    font-weight: 800;
    line-height: 1.2;
    flex: 1;
  }

  .detail-badges { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

  .detail-nav {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .nav-btn {
    padding: 7px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .nav-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; }

  .nav-counter {
    font-size: 13px;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    padding: 0 8px;
  }

  .flag-btn {
    padding: 7px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .flag-btn:hover       { border-color: var(--flag); color: var(--flag); }
  .flag-btn.flagged     { background: rgba(245,158,11,0.15); border-color: var(--flag); color: var(--flag); }

  /* ---- FIELDS GRID ---- */
  .fields-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }

  .field-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .field-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .field-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    word-break: break-all;
    font-family: 'JetBrains Mono', monospace;
  }
  .field-value.empty { color: var(--muted); font-style: italic; font-family: 'Syne', sans-serif; font-weight: 400; }

  /* ---- NOTE BLOCK ---- */
  .section-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 10px;
  }

  .note-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 10px 10px 0;
    padding: 14px 16px;
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 24px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .note-block.empty { color: var(--muted); font-style: italic; border-left-color: var(--border); }

  /* ---- RULES BLOCK ---- */
  .rules-block {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  .rule-chip {
    padding: 5px 12px;
    border-radius: 6px;
    background: rgba(79,142,247,0.1);
    border: 1px solid rgba(79,142,247,0.25);
    color: var(--accent);
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
  }

  /* ---- XML BLOCK ---- */
  .xml-wrap {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .xml-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .xml-toolbar-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .copy-btn {
    padding: 4px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .copy-btn:hover { border-color: var(--accent); color: var(--accent); }
  .copy-btn.copied { border-color: var(--green); color: var(--green); }

  .xml-code {
    padding: 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    line-height: 1.7;
    overflow-x: auto;
    white-space: pre;
    color: #94a3b8;
    max-height: 480px;
    overflow-y: auto;
  }
  .xml-code::-webkit-scrollbar { width: 4px; height: 4px; }
  .xml-code::-webkit-scrollbar-track { background: transparent; }
  .xml-code::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* XML syntax highlighting */
  .xml-tag       { color: #7dd3fc; }
  .xml-attr      { color: #86efac; }
  .xml-val       { color: #fca5a5; }
  .xml-comment   { color: #475569; font-style: italic; }
  .xml-text      { color: #e2e8f0; }

  .xml-empty {
    padding: 20px;
    color: var(--muted);
    font-style: italic;
    font-family: 'Syne', sans-serif;
    font-size: 14px;
  }

  /* ---- BUTTONS ---- */
  .btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }
  .btn:hover          { border-color: var(--accent); }
  .btn.btn-accent     { background: var(--accent); border-color: var(--accent); color: #fff; }
  .btn.btn-accent:hover { background: #3d7ae5; }
  .btn.btn-danger     { background: rgba(239,68,68,0.1); border-color: var(--red); color: var(--red); }

  /* ---- EXPORT MODAL ---- */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    z-index: 100;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    width: 90%;
    max-width: 560px;
    max-height: 80vh;
    overflow-y: auto;
  }

  .modal-title {
    font-size: 18px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .modal-sub { font-size: 13px; color: var(--muted); margin-bottom: 20px; }

  .modal-list { list-style: none; display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }

  .modal-item {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--flag);
    border-radius: 0 8px 8px 0;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 600;
  }

  .modal-item-id { font-size: 11px; color: var(--muted); font-family: 'JetBrains Mono', monospace; margin-top: 2px; }

  .modal-actions { display: flex; gap: 10px; justify-content: flex-end; }

  /* ---- SCROLLBAR GLOBAL ---- */
  ::-webkit-scrollbar       { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  .no-results {
    padding: 24px;
    text-align: center;
    color: var(--muted);
    font-size: 13px;
  }

  /* ---- REVIEWED STATE ---- */
  .sidebar-item.reviewed-item { opacity: 0.45; }
  .sidebar-item.reviewed-item .item-name { text-decoration: line-through; }

  .badge-reviewed { background: rgba(34,197,94,0.15); color: var(--green); }

  .review-card {
    background: rgba(34,197,94,0.08);
    border: 1px solid rgba(34,197,94,0.25);
    border-left: 3px solid var(--green);
    border-radius: 0 10px 10px 0;
    padding: 12px 16px;
    margin-bottom: 24px;
    font-size: 13px;
    line-height: 1.6;
  }
  .review-card .review-by   { font-weight: 700; color: var(--green); }
  .review-card .review-time { color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: 11px; }
  .review-card .review-note { margin-top: 6px; color: var(--text); white-space: pre-wrap; }

  .mark-reviewed-btn {
    padding: 6px 12px;
    border-radius: 8px;
    border: 1px solid var(--green);
    background: rgba(34,197,94,0.1);
    color: var(--green);
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
  }
  .mark-reviewed-btn:hover     { background: var(--green); color: #000; }
  .mark-reviewed-btn.done      { background: var(--green); color: #000; border-color: var(--green); }

  .unmark-btn {
    padding: 5px 10px;
    border-radius: 6px;
    border: 1px solid rgba(239,68,68,0.4);
    background: transparent;
    color: var(--red);
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .unmark-btn:hover { background: rgba(239,68,68,0.15); }

  /* ---- NAME PROMPT OVERLAY ---- */
  .name-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(6px);
    z-index: 200;
    align-items: center;
    justify-content: center;
  }
  .name-overlay.open { display: flex; }

  .name-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    width: 90%;
    max-width: 420px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .name-card h2 { font-size: 20px; font-weight: 800; }
  .name-card p  { font-size: 13px; color: var(--muted); line-height: 1.5; }

  .name-input {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    font-weight: 600;
    outline: none;
    transition: border-color 0.15s;
  }
  .name-input:focus { border-color: var(--accent); }

  .stat-chip.reviewed { background: rgba(34,197,94,0.12); border-color: rgba(34,197,94,0.3); color: var(--green); }

  /* ---- NOTE PANEL ---- */
  .note-panel {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent2);
    border-radius: 0 10px 10px 0;
    padding: 14px 16px;
    margin-bottom: 24px;
    display: none;
    flex-direction: column;
    gap: 10px;
  }
  .note-panel.open { display: flex; }

  .note-panel-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .note-textarea {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 12px;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    line-height: 1.6;
    resize: vertical;
    min-height: 80px;
    outline: none;
    transition: border-color 0.15s;
  }
  .note-textarea:focus { border-color: var(--accent2); }
  .note-textarea::placeholder { color: var(--muted); font-style: italic; }

  .note-panel-actions { display: flex; gap: 8px; }

  .note-save-btn {
    padding: 6px 14px;
    border-radius: 7px;
    border: 1px solid var(--accent2);
    background: rgba(124,58,237,0.15);
    color: var(--accent2);
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
  }
  .note-save-btn:hover { background: var(--accent2); color: #fff; }

  .note-clear-btn {
    padding: 6px 14px;
    border-radius: 7px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .note-clear-btn:hover { border-color: var(--red); color: var(--red); }

  .note-btn {
    padding: 6px 12px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
  }
  .note-btn:hover        { border-color: var(--accent2); color: var(--accent2); }
  .note-btn.has-note     { border-color: var(--accent2); color: var(--accent2); background: rgba(124,58,237,0.1); }
</style>
</head>
<body>

<!-- NAME PROMPT OVERLAY -->
<div class="name-overlay open" id="nameOverlay">
  <div class="name-card">
    <h2>&#128100; Who is reviewing?</h2>
    <p>Your name will be recorded with each exclusion you mark as reviewed, and saved in the review state file.</p>
    <input class="name-input" id="reviewerNameInput" type="text" placeholder="Your name..." maxlength="80"
           onkeydown="if(event.key==='Enter') confirmReviewerName()">
    <input class="name-input" id="baseUrlInput" type="text" placeholder="Server URL (optional) e.g. https://esethost.local" maxlength="200"
           onkeydown="if(event.key==='Enter') confirmReviewerName()"
           style="margin-top:0;font-size:13px;font-weight:400">
    <button class="btn btn-accent" onclick="confirmReviewerName()">Start Review &rarr;</button>
  </div>
</div>

<!-- DROP ZONE -->
<div id="dropzone">
  <div class="drop-logo">ESET Inspect</div>
  <h1 class="drop-title">Exclusion<br>Reviewer</h1>
  <p class="drop-sub">Load your exported JSON file to review exclusions. Optionally load a previous review state file to skip already-reviewed items.</p>
  <div class="drop-box" id="dropBox" onclick="document.getElementById('fileInput').click()">
    <div class="drop-icon">&#128196;</div>
    <div class="drop-label">Drop JSON export here</div>
    <div class="drop-hint">or click to browse &mdash; exported by Export-EsetInspectExclusions.ps1</div>
  </div>
  <input type="file" id="fileInput" accept=".json">
  <div style="display:flex;align-items:center;gap:12px;margin-top:8px">
    <div style="flex:1;height:1px;background:var(--border)"></div>
    <span style="font-size:12px;color:var(--muted)">optionally load previous review state</span>
    <div style="flex:1;height:1px;background:var(--border)"></div>
  </div>
  <div class="drop-box" id="stateDropBox" onclick="document.getElementById('stateFileInput').click()" style="padding:20px 40px">
    <div class="drop-icon" style="width:36px;height:36px;border-radius:10px;font-size:16px">&#128204;</div>
    <div class="drop-label" style="font-size:13px">Load review state file</div>
    <div class="drop-hint" id="stateFileHint">No state file loaded &mdash; load multiple files to merge reviews from different team members</div>
  </div>
  <input type="file" id="stateFileInput" accept=".json">
</div>

<!-- APP -->
<div id="app">
  <!-- Top bar -->
  <div class="topbar">
    <div class="topbar-brand">ESET &mdash; Exclusion Reviewer</div>
    <div class="topbar-stats" id="topbarStats"></div>
    <div class="topbar-spacer"></div>
    <div class="topbar-actions">
      <button class="btn" onclick="toggleStatsPanel()">&#128202; Stats</button>
      <button class="btn" onclick="exportFiltered()">&#8681; Export View</button>
      <button class="btn" onclick="openFlagModal()" id="exportFlagBtn">&#9873; Export Flagged</button>
      <button class="btn btn-accent" onclick="saveStateFile()">&#128190; Save Review State</button>
      <button class="btn" onclick="resetApp()">&#8617; Load New File</button>
    </div>
  </div>

  <!-- Filter bar -->
  <div class="filterbar">
    <div class="search-wrap">
      <span class="search-icon">&#128269;</span>
      <input class="search-input" type="text" id="searchInput" placeholder="Search by name, note, rule ID..." oninput="applyFilters()">
    </div>
    <span class="filter-label">Filter:</span>
    <button class="filter-btn active" id="filterAll"        onclick="setFilter('all')" title="Clear all filters">All</button>
    <button class="filter-btn"        id="filterPending"    onclick="toggleFilter('pending')" title="Not yet reviewed">Pending</button>
    <button class="filter-btn"        id="filterReviewed"   onclick="toggleFilter('reviewed')" title="Marked as reviewed">Reviewed</button>
    <button class="filter-btn"        id="filterEnabled"    onclick="toggleFilter('enabled')" title="Enabled exclusions">Enabled</button>
    <button class="filter-btn"        id="filterDisabled"   onclick="toggleFilter('disabled')" title="Disabled exclusions">Disabled</button>
    <button class="filter-btn"        id="filterFlagged"    onclick="toggleFilter('flagged')" title="Flagged for attention">Flagged</button>
    <button class="filter-btn"        id="filterHasNote"    onclick="toggleFilter('hasnote')" title="Has a note">Has Note</button>
    <button class="filter-btn"        id="filterNoRules"    onclick="toggleFilter('norules')" title="Not linked to any rule">No Rules</button>
    <div style="flex:1"></div>
    <div style="display:flex;gap:6px;align-items:center;border-left:1px solid var(--border);padding-left:12px">
      <button class="mark-reviewed-btn" id="quickReviewBtn" onclick="quickAction('review')" title="Mark current as reviewed (R)">&#10003; Review</button>
      <button class="note-btn"          id="quickNoteBtn"   onclick="quickAction('note')"   title="Add note to current (N)">&#128221; Note</button>
      <button class="flag-btn"          id="quickFlagBtn"   onclick="quickAction('flag')"   title="Flag current (F)">&#9873; Flag</button>
    </div>
  </div>

  <!-- Stats panel -->
  <div class="stats-panel" id="statsPanel">
    <div class="stats-header">
      <span class="stats-title">&#128202; Exclusion Author Statistics</span>
      <button class="stats-toggle" id="statsToggleMode" onclick="toggleStatsMode()" title="Switch between count and percent">Show %</button>
      <span style="font-size:11px;color:var(--muted)">Click an author to exclude from stats</span>
    </div>
    <div class="stats-grid" id="statsGrid"></div>
  </div>

  <!-- Main -->
  <div class="main">
    <aside class="sidebar">
      <ul class="sidebar-list" id="sidebarList"></ul>
    </aside>
    <section class="detail" id="detailPanel">
      <div class="detail-empty">
        <div class="detail-empty-icon">&#128196;</div>
        <div class="detail-empty-text">Select an exclusion from the list</div>
      </div>
    </section>
  </div>
</div>

<!-- Flag export modal -->
<div class="modal-overlay" id="flagModal">
  <div class="modal">
    <div class="modal-title">&#9873; Flagged Exclusions</div>
    <div class="modal-sub" id="flagModalSub"></div>
    <ul class="modal-list" id="flagList"></ul>
    <div class="modal-actions">
      <button class="btn" onclick="closeFlagModal()">Close</button>
      <button class="btn btn-accent" onclick="downloadFlagged()">&#8681; Download JSON</button>
    </div>
  </div>
</div>

<script>
// ============================================================
// STATE
// ============================================================
let allData       = [];
let filteredData  = [];
let flagged       = new Set();
let reviewed      = {};   // { id: { reviewerName, timestamp, note } }
let notes         = {};   // { id: noteText } -- decoupled from reviewed so anyone can add notes
let activeFilters      = new Set();
let statsShowPct       = false;
let excludedReviewers  = new Set();
let currentIndex  = 0;
let reviewerName  = '';
let baseUrl       = '';   // e.g. https://esethost.local
let stateLoaded   = false;

// ============================================================
// REVIEWER NAME PROMPT
// ============================================================
function confirmReviewerName() {
  const val = document.getElementById('reviewerNameInput').value.trim();
  if (!val) {
    document.getElementById('reviewerNameInput').style.borderColor = 'var(--red)';
    return;
  }
  reviewerName = val;
  const urlVal = document.getElementById('baseUrlInput').value.trim().replace(/\/$/, '');
  baseUrl      = urlVal;
  document.getElementById('nameOverlay').classList.remove('open');
}

// ============================================================
// FILE LOADING
// ============================================================
const dropzone      = document.getElementById('dropzone');
const app           = document.getElementById('app');
const fileInput     = document.getElementById('fileInput');
const dropBox       = document.getElementById('dropBox');
const stateDropBox  = document.getElementById('stateDropBox');
const stateFileInput= document.getElementById('stateFileInput');

dropBox.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('drag-over'); dropBox.classList.add('active'); });
dropBox.addEventListener('dragleave', () => { dropzone.classList.remove('drag-over'); dropBox.classList.remove('active'); });
dropBox.addEventListener('drop', e => {
  e.preventDefault();
  dropzone.classList.remove('drag-over');
  dropBox.classList.remove('active');
  const file = e.dataTransfer.files[0];
  if (file) loadFile(file);
});
fileInput.addEventListener('change', e => { if (e.target.files[0]) loadFile(e.target.files[0]); });
stateFileInput.addEventListener('change', e => { if (e.target.files[0]) loadStateFile(e.target.files[0]); });

function loadFile(file) {
  const reader = new FileReader();
  reader.onload = e => {
    try {
      // Strip UTF-8 BOM if present (PS 5.1 Out-File adds it)
      let raw = e.target.result.replace(/^﻿/, '');
      let parsed = JSON.parse(raw);
      if (Array.isArray(parsed)) {
        allData = parsed;
      } else if (parsed.value && Array.isArray(parsed.value)) {
        allData = parsed.value;
      } else {
        allData = [parsed];
      }
      allData = allData.map(d => ({
        ...d,
        enabled:    d.enabled === true || d.enabled === 'True' || d.enabled === 'true',
        isDisabled: d.isDisabled === true || d.isDisabled === 'True' || d.isDisabled === 'true'
            || !(d.enabled === true || d.enabled === 'True' || d.enabled === 'true'),
        hasXml:     !!(d.xmlBody && d.xmlBody.trim() !== ''),
        linkedRules: !!(d.rulesCount > 0 || (d.ruleIds && d.ruleIds.toString().trim() !== '')),
        ruleCount:  d.rulesCount || d.ruleCount || 0,
      }));
      initApp();
    } catch(err) {
      alert('Failed to parse JSON file: ' + err.message);
    }
  };
  reader.readAsText(file, 'UTF-8');
}

function loadStateFile(file) {
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const raw    = e.target.result.replace(/^﻿/, '');
      const parsed = JSON.parse(raw);
      // Validate it's a state file -- must have at least one of these keys
      const isValidState = parsed.reviewed || parsed.flagged || parsed.notes;
      if (!isValidState) {
        alert('Not a valid review state file.\n\nTop-level keys found: ' + Object.keys(parsed).join(', '));
        return;
      }



      let added = 0, skipped = 0;

      // Merge reviewed entries
      if (parsed.reviewed && typeof parsed.reviewed === 'object') {
        Object.entries(parsed.reviewed).forEach(([id, entry]) => {
          if (!reviewed[id]) { reviewed[id] = entry; added++; }
          else skipped++;
        });
        // Extract inline notes from reviewed entries
        Object.entries(parsed.reviewed).forEach(([id, entry]) => {
          if (entry.note && !notes[id]) notes[id] = entry.note;
        });
      }

      // Merge standalone notes
      if (parsed.notes && typeof parsed.notes === 'object') {
        Object.entries(parsed.notes).forEach(([id, text]) => {
          if (!notes[id]) notes[id] = text;
        });
      }

      // Merge flagged items -- always processed regardless of reviewed state
      if (Array.isArray(parsed.flagged)) {
        parsed.flagged.forEach(id => flagged.add(String(id)));
      }

      stateLoaded = true;
      const total      = Object.keys(reviewed).length;
      const totalFlags = flagged.size;
      const totalNotes = Object.keys(notes).length;
      document.getElementById('stateFileHint').textContent =
        `State merged: ${total} reviewed, ${totalFlags} flagged, ${totalNotes} notes (${added} new reviews added)`;
      document.getElementById('stateDropBox').style.borderColor = 'var(--green)';
      document.getElementById('stateDropBox').style.borderStyle = 'solid';
      // If app already open, refresh
      if (app.style.display !== 'none') { updateStats(); applyFilters(); }
    } catch(err) {
      alert('Failed to parse state file: ' + err.message);
    }
  };
  reader.readAsText(file, 'UTF-8');
}

function initApp() {
  // Do NOT clear flagged/reviewed/notes here -- state file may have been
  // loaded before the export, and initApp must not wipe it.
  activeFilters.clear();
  currentIndex  = 0;
  document.getElementById('searchInput').value = '';
  setFilter('all');
  dropzone.style.display = 'none';
  app.style.display = 'flex';
  updateStats();
  // Refresh stats panel if already open
  const sp = document.getElementById('statsPanel');
  if (sp && sp.classList.contains('open')) renderStats();
}

function resetApp() {
  allData = []; filteredData = []; flagged.clear(); reviewed = {}; notes = {};
  // Reviewer name is kept across sessions
  app.style.display = 'none';
  dropzone.style.display = 'flex';
  fileInput.value = '';
  stateFileInput.value = '';
}

// ============================================================
// FILTERING
// ============================================================
function setFilter(f) {
  // 'all' clears all active filters
  activeFilters.clear();
  document.getElementById('filterAll').classList.add('active');
  ['pending','reviewed','enabled','disabled','flagged','hasnote','norules'].forEach(k => {
    const id  = 'filter' + k.charAt(0).toUpperCase() + k.slice(1);
    const btn = document.getElementById(id);
    if (btn) btn.classList.remove('active','active-red','active-yellow','active-green','active-purple');
  });
  applyFilters();
}

function toggleFilter(f) {
  // Toggle this filter on/off; multiple can be active simultaneously
  if (activeFilters.has(f)) activeFilters.delete(f);
  else activeFilters.add(f);

  // Update All button -- active only when nothing else is active
  const allBtn = document.getElementById('filterAll');
  if (allBtn) {
    if (activeFilters.size === 0) allBtn.classList.add('active');
    else allBtn.classList.remove('active');
  }

  // Update each filter button
  const colorMap = { disabled: 'active-red', flagged: 'active-yellow', reviewed: 'active-green', hasnote: 'active-purple' };
  ['pending','reviewed','enabled','disabled','flagged','hasnote','norules'].forEach(k => {
    const id  = 'filter' + k.charAt(0).toUpperCase() + k.slice(1);
    const btn = document.getElementById(id);
    if (!btn) return;
    btn.classList.remove('active','active-red','active-yellow','active-green','active-purple');
    if (activeFilters.has(k)) btn.classList.add(colorMap[k] || 'active');
  });

  applyFilters();
}

function applyFilters() {
  const q = document.getElementById('searchInput').value.toLowerCase().trim();
  filteredData = allData.filter(d => {
    const isRev     = !!reviewed[String(d.id)];
    const isFlagged = flagged.has(String(d.id));
    const hasNote   = !!(notes[String(d.id)] && notes[String(d.id)].trim());

    // Multi-filter: ALL active filters must match (AND logic)
    if (activeFilters.has('pending')   && isRev)             return false;
    if (activeFilters.has('reviewed')  && !isRev)            return false;
    if (activeFilters.has('enabled')   && d.isDisabled)      return false;
    if (activeFilters.has('disabled')  && !d.isDisabled)     return false;
    if (activeFilters.has('flagged')   && !isFlagged)        return false;
    if (activeFilters.has('hasnote')   && !hasNote)          return false;
    if (activeFilters.has('norules')   && d.linkedRules)     return false;

    if (q) {
      const haystack = [d.name, d.note, d.ruleIds, d.ruleUuids, d.uuid,
                        d.xmlBody, d.author, d.targets, d.ruleName,
                        notes[String(d.id)]]
        .filter(Boolean).join(' ').toLowerCase();
      if (!haystack.includes(q)) return false;
    }
    return true;
  });

  currentIndex = 0;
  renderSidebar();
  if (filteredData.length > 0) renderDetail(0);
  else document.getElementById('detailPanel').innerHTML = '<div class="detail-empty"><div class="detail-empty-icon">&#128269;</div><div class="detail-empty-text">No exclusions match the current filter</div></div>';
}

// ============================================================
// SIDEBAR
// ============================================================
function renderSidebar() {
  const list = document.getElementById('sidebarList');
  if (filteredData.length === 0) {
    list.innerHTML = '<li class="no-results">No results</li>';
    return;
  }
  list.innerHTML = filteredData.map((d, i) => {
    const isFlagged  = flagged.has(String(d.id));
    const isRev      = !!reviewed[String(d.id)];
    const statusBadge = d.isDisabled
      ? '<span class="badge badge-disabled">DISABLED</span>'
      : '<span class="badge badge-enabled">ENABLED</span>';
    const ruleBadge  = d.linkedRules
      ? `<span class="badge badge-rules">${d.ruleCount} rule${d.ruleCount !== 1 ? 's' : ''}</span>`
      : '';
    const flagBadge  = isFlagged ? '<span class="badge badge-flag">&#9873;</span>' : '';
    const revBadge   = isRev ? '<span class="badge badge-reviewed">&#10003;</span>' : '';
    const noteBadge  = notes[String(d.id)] ? '<span class="badge" style="background:rgba(124,58,237,0.15);color:var(--accent2)">&#128221;</span>' : '';
    const xmlBadge   = !d.hasXml ? '<span class="badge badge-noxml">no XML</span>' : '';
    return `<li class="sidebar-item${i === currentIndex ? ' active' : ''}${isFlagged ? ' flagged-item' : ''}${isRev ? ' reviewed-item' : ''}"
               onclick="selectItem(${i})">
      <div class="item-name" title="${esc(d.name || '(unnamed)')}">${esc(d.name || '(unnamed)')}</div>
      <div class="item-meta">${statusBadge}${ruleBadge}${revBadge}${noteBadge}${flagBadge}${xmlBadge}</div>
    </li>`;
  }).join('');
}

function selectItem(i) {
  currentIndex = i;
  renderSidebar();
  renderDetail(i);
  updateQuickBar();
  const items = document.querySelectorAll('.sidebar-item');
  if (items[i]) items[i].scrollIntoView({ block: 'nearest' });
}

// ============================================================
// DETAIL PANEL
// ============================================================
function renderDetail(i) {
  const d = filteredData[i];
  if (!d) return;

  const isFlagged = flagged.has(String(d.id));
  const revEntry  = reviewed[String(d.id)];
  const isRev     = !!revEntry;
  const hasNote   = !!(notes[String(d.id)] && notes[String(d.id)].trim());

  const statusBadge = d.isDisabled
    ? '<span class="badge badge-disabled" style="font-size:13px;padding:4px 10px">DISABLED</span>'
    : '<span class="badge badge-enabled"  style="font-size:13px;padding:4px 10px">ENABLED</span>';

  // Reviewed status block
  const reviewedHtml = isRev
    ? `<div class="review-card">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap">
          <div>
            <span class="review-by">&#10003; Reviewed by ${esc(revEntry.reviewerName)}</span>
            &nbsp;&nbsp;
            <span class="review-time">${esc(new Date(revEntry.timestamp).toLocaleString())}</span>
          </div>
          <button class="unmark-btn" onclick="unmarkReviewed('${d.id}')">&#8617; Mark as Pending</button>
        </div>

      </div>`
    : '';

  // Rules section
  const ruleIdsArr   = d.ruleIds   ? d.ruleIds.toString().split(',').map(x => x.trim()).filter(Boolean) : [];
  const ruleUuidsArr = d.ruleUuids ? d.ruleUuids.toString().split(',').map(x => x.trim()).filter(Boolean) : [];
  const ruleNamesArr = d.ruleName  ? d.ruleName.toString().split(';').map(x => x.trim()).filter(Boolean) : [];
  const rulesHtml = ruleIdsArr.length > 0
    ? ruleIdsArr.map((id, idx) => {
        const name = ruleNamesArr[idx] ? `<div style="font-size:11px;color:var(--muted);margin-top:2px">${esc(ruleNamesArr[idx])}</div>` : '';
        return `<div class="rule-chip" style="display:flex;flex-direction:column">Rule ID: ${esc(id)}${name}</div>`;
      }).join('')
    : (d.rulesCount > 0
        ? `<span class="rule-chip">${d.rulesCount} rule${d.rulesCount!==1?'s':''} (IDs not available in this export)</span>`
        : '<span style="color:var(--muted);font-size:13px;font-style:italic">Not linked to any rule (global exclusion)</span>');

  // XML
  const xmlHtml = d.hasXml
    ? `<div class="xml-wrap">
        <div class="xml-toolbar">
          <span class="xml-toolbar-label">XML Criteria Body</span>
          <button class="copy-btn" id="copyBtn" onclick="copyXml()">Copy XML</button>
        </div>
        <div class="xml-code" id="xmlCode">${highlightXml(prettyXml(d.xmlBody))}</div>
       </div>`
    : `<div class="xml-wrap">
        <div class="xml-toolbar"><span class="xml-toolbar-label">XML Criteria Body</span></div>
        <div class="xml-empty">No XML body &mdash; this is a standard criteria exclusion or was exported without -FetchDetails</div>
       </div>`;

  const noteDisplayHtml = hasNote
    ? '<div class="section-label">&#128221; Note</div>' +
      '<div class="note-block" style="border-left-color:var(--accent2);margin-bottom:20px">' + esc(notes[String(d.id)]) + '</div>'
    : '';

  document.getElementById('detailPanel').innerHTML = `
    <div class="detail-nav">
      <button class="nav-btn" onclick="navigate(-1)" ${i === 0 ? 'disabled' : ''}>&larr; Prev</button>
      <span class="nav-counter">${i + 1} / ${filteredData.length}</span>
      <button class="nav-btn" onclick="navigate(1)" ${i === filteredData.length - 1 ? 'disabled' : ''}>Next &rarr;</button>
    </div>

    ${reviewedHtml}

    <div class="note-panel" id="notePanel">
      <div class="note-panel-label">&#128221; Note</div>
      <textarea class="note-textarea" id="noteTextarea" placeholder="Add a note about this exclusion..." rows="4">${hasNote ? esc(getNoteForId('${d.id}')) : ''}</textarea>
      <div class="note-panel-actions">
        <button class="note-save-btn" onclick="saveNote('${d.id}')">Save Note</button>
        <button class="note-clear-btn" onclick="clearNote('${d.id}')">Clear</button>
        <button class="note-clear-btn" onclick="toggleNotePanel('${d.id}')">Cancel</button>
      </div>
    </div>

    ${noteDisplayHtml}

    <div class="detail-header">
      <div class="detail-title">${esc(d.name || '(unnamed)')}</div>
      <div class="detail-badges">${statusBadge}</div>
    </div>

    <div class="fields-grid">
      <div class="field-card">
        <div class="field-label">Exclusion URL</div>
        <div class="field-value" style="word-break:break-all">
          ${baseUrl
            ? '<a href="' + baseUrl + '/console/exclusion/' + esc(String(d.id ?? '')) + '" target="_blank" rel="noopener" style="color:var(--accent);text-decoration:none;font-size:12px">' + baseUrl + '/console/exclusion/' + esc(String(d.id ?? '')) + '</a>'
            : esc(String(d.id ?? ''))}
        </div>
      </div>
      <div class="field-card">
        <div class="field-label">Author</div>
        <div class="field-value ${d.author && d.author.trim() ? '' : 'empty'}">${d.author && d.author.trim() ? esc(d.author) : 'n/a'}</div>
      </div>
      <div class="field-card">
        <div class="field-label">Created</div>
        <div class="field-value ${d.timestamp ? '' : 'empty'}">${d.timestamp ? esc(new Date(d.timestamp).toLocaleString()) : 'n/a'}</div>
      </div>
      <div class="field-card">
        <div class="field-label">Access Group</div>
        <div class="field-value ${d.accessGroup ? '' : 'empty'}">${d.accessGroup ? esc(d.accessGroup) : 'n/a'}</div>
      </div>
      <div class="field-card">
        <div class="field-label">Type</div>
        <div class="field-value" style="color:${d.isAdvanced ? 'var(--accent2)' : 'var(--accent)'}">${d.isAdvanced ? 'Advanced (XML Query)' : 'Standard (Criteria)'}</div>
      </div>
      <div class="field-card">
        <div class="field-label">Internal (ESET)</div>
        <div class="field-value" style="color:${d.isInternal ? 'var(--yellow)' : 'var(--green)'}">${d.isInternal ? 'Yes' : 'No'}</div>
      </div>
      <div class="field-card">
        <div class="field-label">Hit Count</div>
        <div class="field-value ${d.hitCount ? '' : 'empty'}">${d.hitCount ?? 0}</div>
      </div>
      <div class="field-card">
        <div class="field-label">Linked Rules</div>
        <div class="field-value" style="color:${d.linkedRules ? 'var(--accent)' : 'var(--muted)'}">${d.ruleCount || 0} rule${d.ruleCount !== 1 ? 's' : ''}</div>
      </div>
      <div class="field-card">
        <div class="field-label">Has XML Body</div>
        <div class="field-value" style="color:${d.hasXml ? 'var(--green)' : 'var(--muted)'}">${d.hasXml ? 'Yes' : 'No'}</div>
      </div>
      <div class="field-card">
        <div class="field-label">UUID</div>
        <div class="field-value" style="font-size:11px">${esc(d.uuid ?? '')}</div>
      </div>
    </div>

    <div class="section-label">Note</div>
    <div class="note-block${!d.note || d.note.trim() === '' ? ' empty' : ''}">${d.note && d.note.trim() !== '' ? esc(d.note) : 'No note set'}</div>

    <div class="section-label">Targets</div>
    <div class="note-block${!d.targets || d.targets.trim() === '' || d.targets === 'All' ? ' empty' : ''}" style="margin-bottom:24px">
      ${d.targets && d.targets.trim() && d.targets !== 'All'
        ? esc(d.targets).replace(/,\s*/g, '<br>')
        : (d.targets === 'All' ? 'All computers' : 'No specific targets defined')}
    </div>

    <div class="section-label">Criteria Summary</div>
    <div class="fields-grid" style="margin-bottom:24px">
      ${[['Files', d.criteriaFiles], ['Paths', d.criteriaPaths], ['CMD Lines', d.criteriaCmdLine],
         ['Signers', d.criteriaSigners], ['Hashes', d.criteriaHashes], ['Users', d.criteriaUsers]]
        .map(([l,v]) => `<div class="field-card">
          <div class="field-label">${l}</div>
          <div class="field-value ${v ? '' : 'empty'}">${v || 0}</div>
        </div>`).join('')}
    </div>

    <div class="section-label">Linked Rules</div>
    <div class="rules-block">${rulesHtml}</div>

    ${xmlHtml}
  `;
}

// ============================================================
// REVIEW STATE
// ============================================================
function markReviewed(id) {
  id = String(id);
  if (reviewed[id]) { unmarkReviewed(id); return; }

  reviewed[id] = {
    reviewerName: reviewerName || 'Unknown',
    timestamp:    new Date().toISOString(),
    note:         (notes[id] || '').trim(),  // use note if already written
    exclusionId:  id,
  };
  updateStats();
  renderSidebar();
  renderDetail(currentIndex);
  updateQuickBar();
  // Auto-advance to next unreviewed item
  const next = filteredData.slice(currentIndex + 1).findIndex(x => !reviewed[String(x.id)]);
  if (next !== -1) selectItem(currentIndex + 1 + next);
}

function unmarkReviewed(id) {
  id = String(id);
  delete reviewed[id];
  updateStats();
  renderSidebar();
  renderDetail(currentIndex);
  updateQuickBar();
}

function getNoteForId(id) {
  return notes[String(id)] || '';
}

function toggleNotePanel(id) {
  const panel = document.getElementById('notePanel');
  if (!panel) return;
  const isOpen = panel.classList.contains('open');
  if (isOpen) {
    panel.classList.remove('open');
  } else {
    // Pre-fill textarea with existing note
    const ta = document.getElementById('noteTextarea');
    if (ta) ta.value = notes[String(id)] || '';
    panel.classList.add('open');
    if (ta) ta.focus();
  }
}

function saveNote(id) {
  id = String(id);
  const ta = document.getElementById('noteTextarea');
  if (!ta) return;
  const text = ta.value.trim();
  if (text) {
    notes[id] = text;
    // Also update the note on the reviewed entry if it exists
    if (reviewed[id]) reviewed[id].note = text;
  } else {
    delete notes[id];
    if (reviewed[id]) reviewed[id].note = '';
  }
  // Close the panel and refresh
  const panel = document.getElementById('notePanel');
  if (panel) panel.classList.remove('open');
  updateStats();
  renderSidebar();
  renderDetail(currentIndex);
  updateQuickBar();
}

function clearNote(id) {
  id = String(id);
  const ta = document.getElementById('noteTextarea');
  if (ta) ta.value = '';
  delete notes[id];
  if (reviewed[id]) reviewed[id].note = '';
  const panel = document.getElementById('notePanel');
  if (panel) panel.classList.remove('open');
  updateStats();
  renderSidebar();
  renderDetail(currentIndex);
  updateQuickBar();
}

function saveStateFile() {
  const revCount = Object.keys(reviewed).length;
  const hasAnything = revCount > 0 || flagged.size > 0 || Object.keys(notes).length > 0;
  if (!hasAnything) {
    alert('Nothing to save yet -- mark some exclusions as reviewed, flag them, or add notes first.');
    return;
  }

  // Build a summary of who has reviewed what, for the audit header
  const byReviewer = {};
  Object.values(reviewed).forEach(e => {
    const name = e.reviewerName || 'Unknown';
    byReviewer[name] = (byReviewer[name] || 0) + 1;
  });

  // Sync any standalone notes into reviewed entries before saving
  Object.entries(notes).forEach(([id, text]) => {
    if (!reviewed[id]) return;  // note without review stays in notes only
    reviewed[id].note = text;
  });

  const state = {
    _info:          'ESET Inspect Exclusion Review State File -- save this back to the shared file share to keep everyone in sync',
    _savedAt:       new Date().toISOString(),
    _savedBy:       reviewerName || 'Unknown',
    _totalReviewed: revCount,
    _totalFlagged:  flagged.size,
    _reviewerSummary: byReviewer,
    _usage:         'Load this file alongside a new exclusion export to skip already-reviewed items. Multiple state files can be loaded one after another -- they are merged.',
    reviewed,
    notes,
    flagged: Array.from(flagged),
  };

  const blob = new Blob([JSON.stringify(state, null, 2)], { type: 'application/json' });
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  // Fixed filename so reviewers always overwrite the same file on the share
  a.download = 'ESET_ExclusionReviewState.json';
  a.click();
}

// ============================================================
// STATS
// ============================================================
function updateStats() {
  const total    = allData.length;
  const enabled  = allData.filter(d => !d.isDisabled).length;
  const disabled = allData.filter(d =>  d.isDisabled).length;
  const nRev     = Object.keys(reviewed).filter(id => allData.some(d => String(d.id) === id)).length;
  const pending  = total - nRev;
  const nFlagged = flagged.size;
  document.getElementById('topbarStats').innerHTML = '<span class="stat-chip total">Total: ' + total + '</span>'
    + '<span class="stat-chip enabled">Enabled: ' + enabled + '</span>'
    + '<span class="stat-chip disabled">Disabled: ' + disabled + '</span>'
    + '<span class="stat-chip reviewed">Reviewed: ' + nRev + '</span>'
    + '<span class="stat-chip flagged">Pending: ' + pending + ' &nbsp;|&nbsp; Flagged: ' + nFlagged + '</span>';
  // Refresh stats panel if open
  const sp = document.getElementById('statsPanel');
  if (sp && sp.classList.contains('open')) renderStats();
}

// ============================================================
// FLAG / EXPORT
// ============================================================
function toggleFlag(id) {
  id = String(id);
  if (flagged.has(id)) flagged.delete(id);
  else flagged.add(id);
  updateStats();
  renderSidebar();
  renderDetail(currentIndex);
  updateQuickBar();
}

function openFlagModal() {
  const flaggedItems = allData.filter(d => flagged.has(String(d.id)));
  const sub = document.getElementById('flagModalSub');
  const list = document.getElementById('flagList');

  if (flaggedItems.length === 0) {
    sub.textContent  = 'No exclusions have been flagged yet.';
    list.innerHTML   = '';
  } else {
    sub.textContent = `${flaggedItems.length} exclusion(s) flagged for attention.`;
    list.innerHTML  = flaggedItems.map(d => `
      <li class="modal-item">
        <div>${esc(d.name || '(unnamed)')}</div>
        <div class="modal-item-id">ID: ${esc(String(d.id ?? ''))} &nbsp;|&nbsp; ${d.isDisabled ? 'DISABLED' : 'ENABLED'}</div>
      </li>`).join('');
  }
  document.getElementById('flagModal').classList.add('open');
}

function closeFlagModal() {
  document.getElementById('flagModal').classList.remove('open');
}

function downloadFlagged() {
  const flaggedItems = allData.filter(d => flagged.has(String(d.id)));
  if (flaggedItems.length === 0) { alert('No flagged exclusions to export.'); return; }
  const blob = new Blob([JSON.stringify(flaggedItems, null, 2)], { type: 'application/json' });
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  a.download = `ESET_Flagged_Exclusions_${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  closeFlagModal();
}

// ============================================================
// XML / UTILS
// ============================================================
function copyXml() {
  const d = filteredData[currentIndex];
  if (!d || !d.xmlBody) return;
  navigator.clipboard.writeText(d.xmlBody).then(() => {
    const btn = document.getElementById('copyBtn');
    if (btn) { btn.textContent = 'Copied!'; btn.classList.add('copied'); setTimeout(() => { btn.textContent = 'Copy XML'; btn.classList.remove('copied'); }, 2000); }
  });
}

function highlightXml(xml) {
  if (!xml) return '';
  let s = xml.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  s = s.replace(/(&lt;!--[\s\S]*?--&gt;)/g, '<span class="xml-comment">$1</span>');
  s = s.replace(/(&lt;\/?)([\w:\-\.]+)((?:\s+[\w:\-\.]+\s*=\s*&quot;[^&]*&quot;)*)\s*(\/?&gt;)/g,
    (_, open, tag, attrs, close) => {
      const attrsHtml = attrs.replace(/([\w:\-\.]+)\s*=\s*(&quot;[^&]*&quot;)/g,
        '<span class="xml-attr">$1</span>=<span class="xml-val">$2</span>');
      return `${open}<span class="xml-tag">${tag}</span>${attrsHtml}${close}`;
    });
  s = s.replace(/(&lt;\/?)([\w:\-\.]+)(\s*\/?&gt;)/g,
    (m, open, tag, close) => `${open}<span class="xml-tag">${tag}</span>${close}`);
  return s;
}

function esc(s) {
  return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function navigate(dir) {
  const next = currentIndex + dir;
  if (next >= 0 && next < filteredData.length) selectItem(next);
}

// ============================================================
// STATS PANEL
// ============================================================
function toggleStatsPanel() {
  const panel = document.getElementById('statsPanel');
  if (!panel) return;
  panel.classList.toggle('open');
  if (panel.classList.contains('open')) renderStats();
}

function toggleStatsMode() {
  statsShowPct = !statsShowPct;
  const btn = document.getElementById('statsToggleMode');
  if (btn) { btn.textContent = statsShowPct ? 'Show #' : 'Show %'; btn.classList.toggle('on', statsShowPct); }
  renderStats();
}

function renderStats() {
  const grid = document.getElementById('statsGrid');
  if (!grid) return;

  // Count exclusions per author from the loaded export data
  // excludedReviewers Set is reused here as "excludedAuthors" for filtering
  const counts = {};
  allData.forEach(d => {
    const name = (d.author && d.author.trim()) ? d.author.trim() : '(unknown)';
    counts[name] = (counts[name] || 0) + 1;
  });

  if (Object.keys(counts).length === 0) {
    grid.innerHTML = '<span style="color:var(--muted);font-size:13px;font-style:italic">No exclusion data loaded yet.</span>';
    return;
  }

  // Total excluding any excluded authors (for percentage calculation)
  const includedTotal = Object.entries(counts)
    .filter(([name]) => !excludedReviewers.has(name))
    .reduce((sum, [, n]) => sum + n, 0);
  const grandTotal = Object.values(counts).reduce((s, n) => s + n, 0);

  const maxCount = Math.max(...Object.values(counts));

  grid.innerHTML = Object.entries(counts)
    .sort((a, b) => b[1] - a[1])
    .map(([name, count]) => {
      const isExcluded = excludedReviewers.has(name);
      const base       = statsShowPct ? (isExcluded ? grandTotal : includedTotal) : grandTotal;
      const pct        = base > 0 ? ((count / base) * 100).toFixed(1) : '0.0';
      const barWidth   = maxCount > 0 ? Math.round((count / maxCount) * 100) : 0;
      const label      = statsShowPct ? pct + '%' : count + ' / ' + grandTotal;
      return '<div class="stats-row' + (isExcluded ? ' excluded' : '') + '" onclick="toggleExcludeAuthor(this.dataset.name)" data-name="' + esc(name) + '" title="Click to exclude this author from stats">'
        + '<span class="stats-name">' + esc(name) + '</span>'
        + '<div class="stats-bar-wrap"><div class="stats-bar" style="width:' + (isExcluded ? 0 : barWidth) + '%"></div></div>'
        + '<span class="stats-count">' + label + '</span>'
        + '</div>';
    }).join('');
}

function toggleExcludeAuthor(name) {
  if (excludedReviewers.has(name)) excludedReviewers.delete(name);
  else excludedReviewers.add(name);
  renderStats();
}

// ============================================================
// XML PRETTY PRINT
// ============================================================
function prettyXml(xml) {
  if (!xml || !xml.trim()) return xml;
  try {
    // Use DOMParser to parse and re-serialise with indentation
    const parser = new DOMParser();
    const doc    = parser.parseFromString(xml.trim(), 'application/xml');
    const err    = doc.querySelector('parsererror');
    if (err) return xml; // not valid XML -- return as-is
    return serializeXml(doc.documentElement, 0);
  } catch(e) { return xml; }
}

function serializeXml(node, depth) {
  const indent = '  '.repeat(depth);
  if (node.nodeType === 3) { // text node
    const text = node.textContent.trim();
    return text ? indent + text : '';
  }
  if (node.nodeType !== 1) return ''; // not element

  const tag   = node.tagName;
  const attrs = Array.from(node.attributes)
    .map(a => ' ' + a.name + '="' + a.value + '"').join('');

  const children = Array.from(node.childNodes)
    .map(c => serializeXml(c, depth + 1))
    .filter(s => s.trim() !== '');

  if (children.length === 0) return indent + '<' + tag + attrs + '/>';
  if (children.length === 1 && !children[0].includes('\n')) {
    return indent + '<' + tag + attrs + '>' + children[0].trim() + '</' + tag + '>';
  }
  return indent + '<' + tag + attrs + '>\n' + children.join('\n') + '\n' + indent + '</' + tag + '>';
}

// ============================================================
// QUICK ACTION BAR (fixed in filterbar, always visible)
// ============================================================
function updateQuickBar() {
  // Update the three quick action buttons in the filterbar
  // to reflect the current item's state
  const d         = filteredData[currentIndex];
  const revBtn    = document.getElementById('quickReviewBtn');
  const noteBtn   = document.getElementById('quickNoteBtn');
  const flagBtn   = document.getElementById('quickFlagBtn');
  if (!revBtn || !noteBtn || !flagBtn) return;

  if (!d) {
    revBtn.disabled = noteBtn.disabled = flagBtn.disabled = true;
    return;
  }
  revBtn.disabled = noteBtn.disabled = flagBtn.disabled = false;

  const isRev     = !!reviewed[String(d.id)];
  const hasNote   = !!(notes[String(d.id)] && notes[String(d.id)].trim());
  const isFlagged = flagged.has(String(d.id));

  revBtn.textContent  = isRev     ? '✓ Reviewed'  : '✓ Review';
  revBtn.className    = 'mark-reviewed-btn' + (isRev ? ' done' : '');

  noteBtn.textContent = hasNote   ? '📝 Edit Note' : '📝 Note';
  noteBtn.className   = 'note-btn' + (hasNote ? ' has-note' : '');

  flagBtn.textContent = isFlagged ? '⚑ Unflag'    : '⚑ Flag';
  flagBtn.className   = 'flag-btn' + (isFlagged ? ' flagged' : '');
}

function quickAction(action) {
  const d = filteredData[currentIndex];
  if (!d) return;
  if (action === 'review') markReviewed(String(d.id));
  if (action === 'flag')   toggleFlag(String(d.id));
  if (action === 'note')   toggleNotePanel(String(d.id));
}

// ============================================================
// EXPORT FILTERED VIEW
// ============================================================
function exportFiltered() {
  if (filteredData.length === 0) {
    alert('No exclusions in the current view to export.');
    return;
  }

  // Build export: each exclusion with its review state, notes and flag merged in
  const exportData = filteredData.map(d => {
    const id      = String(d.id);
    const revEntry = reviewed[id] || null;
    return Object.assign({}, d, {
      _reviewState: {
        isReviewed:   !!revEntry,
        reviewedBy:   revEntry ? revEntry.reviewerName : null,
        reviewedAt:   revEntry ? revEntry.timestamp    : null,
        isFlagged:    flagged.has(id),
        note:         notes[id] || (revEntry ? revEntry.note : null) || null,
      }
    });
  });

  // Describe active filters for filename
  const filterDesc = activeFilters.size > 0
    ? Array.from(activeFilters).join('_')
    : 'all';

  const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  a.download = 'ESET_Exclusions_' + filterDesc + '_' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
}

document.addEventListener('keydown', e => {
  if (app.style.display === 'none') return;
  if (document.getElementById('flagModal').classList.contains('open')) return;
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
  if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); navigate(1); }
  if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); navigate(-1); }
  if (e.key === 'f' || e.key === 'F') { const d = filteredData[currentIndex]; if (d) toggleFlag(String(d.id)); }
  if (e.key === 'r' || e.key === 'R') { const d = filteredData[currentIndex]; if (d) markReviewed(String(d.id)); }
});
